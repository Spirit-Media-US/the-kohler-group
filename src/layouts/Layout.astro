---
import { ViewTransitions } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	canonicalURL?: string;
	ogImage?: string;
	heroPreload?: string;
}

const {
	title,
	description = 'Barbara Kohler — Christian counseling, marriage intensives, and individual therapy in Huntersville, NC. Faith-based psychotherapy near Charlotte and Lake Norman.',
	canonicalURL = Astro.url.href,
	ogImage = 'https://cdn.sanity.io/images/2bom5gqg/production/69ff224b35aa2d4c0e57339b5449330d55bf8095-468x311.jpg',
	heroPreload,
} = Astro.props;

const siteName = 'The Kohler Group PLLC';
const ogImageURL = ogImage.startsWith('http')
	? ogImage
	: new URL(ogImage, Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="https://cdn.sanity.io/images/2bom5gqg/production/c60dd6674bab6d1f50562e6ff3f61365e0639f1a-1416x921.png?w=180&h=180&fit=crop" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="generator" content={Astro.generator} />
		<meta name="author" content="Barbara Kohler, LCMHC" />
		<meta name="theme-color" content="#173862" />
		<meta name="robots" content="index, follow" />
		<meta name="msvalidate.01" content="477910DF31D77AFDFCAE62DF5E095405" />
		<title>{title}</title>

		{heroPreload && <link rel="preload" as="image" href={heroPreload} fetchpriority="high" />}

		<!-- Google Fonts: Montserrat (non-blocking) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<!-- Open Graph -->
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="The Kohler Group PLLC — Christian counseling in Huntersville, NC" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<!-- Page-level head slot (JSON-LD, etc.) -->
		<slot name="head" />

		<ViewTransitions />

		<!-- Google Analytics 4 (loaded on first user interaction to protect LCP/TBT) -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			window.gtag = gtag;
			function loadGA() {
				if (window.__gaLoaded) return;
				window.__gaLoaded = true;
				var s = document.createElement('script');
				s.async = true;
				s.src = 'https://www.googletagmanager.com/gtag/js?id=G-RZFT197G0F';
				document.head.appendChild(s);
				gtag('js', new Date());
				gtag('config', 'G-RZFT197G0F');
			}
			var gaEvents = ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'];
			function gaTrigger(){ gaEvents.forEach(function(e){ window.removeEventListener(e, gaTrigger, {passive:true}); }); loadGA(); }
			gaEvents.forEach(function(e){ window.addEventListener(e, gaTrigger, {passive:true, once:true}); });
			// Fallback: load after 8s even if no interaction (keeps analytics intact)
			setTimeout(function(){ if(!window.__gaLoaded) loadGA(); }, 8000);
		</script>

		<!-- LocalBusiness JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": ["ProfessionalService", "MedicalBusiness"],
			"name": "The Kohler Group PLLC",
			"alternateName": "The Kohler Group",
			"description": "Faith-based Christian counseling practice in Huntersville, NC offering individual therapy, marriage counseling, couples therapy, psychotherapy intensives, EMDR, and Re-decision Therapy. Serving Charlotte, Lake Norman, and all of North Carolina via telehealth.",
			"url": "https://thekohlergroup.net",
			"telephone": "+1-252-758-8636",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "13420 Reese Blvd W",
				"addressLocality": "Huntersville",
				"addressRegion": "NC",
				"postalCode": "28078",
				"addressCountry": "US"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": 35.4107,
				"longitude": -80.8429
			},
			"openingHoursSpecification": [
				{
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
					"opens": "09:00",
					"closes": "17:00"
				}
			],
			"priceRange": "$$",
			"founder": {
				"@type": "Person",
				"name": "Barbara Kohler",
				"jobTitle": "Licensed Clinical Mental Health Counselor",
				"honorificSuffix": "MS, LCMHC"
			},
			"areaServed": [
				{ "@type": "City", "name": "Huntersville" },
				{ "@type": "City", "name": "Charlotte" },
				{ "@type": "City", "name": "Cornelius" },
				{ "@type": "City", "name": "Davidson" },
				{ "@type": "Place", "name": "Lake Norman Area" },
				{ "@type": "State", "name": "North Carolina" }
			],
			"serviceType": [
				"Christian Counseling",
				"Faith-Based Counseling",
				"Biblical Counseling",
				"Biblical Psychotherapy",
				"Spirit-Filled Therapy",
				"Kingdom Mental Health",
				"Marriage Counseling",
				"Couples Therapy",
				"Individual Therapy",
				"Psychotherapy Intensives",
				"EMDR Therapy",
				"Re-decision Therapy",
				"Advanced Integrative Therapy",
				"Trauma Resolution Energy Therapy",
				"Inner Child Work",
				"Transactional Analysis",
				"Double Chair Work",
				"Telehealth Therapy"
			],
			"hasOfferCatalog": {
				"@type": "OfferCatalog",
				"name": "Christian Counseling Services",
				"itemListElement": [
					{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Individual Christian Counseling" } },
					{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Marriage Counseling" } },
					{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Couples Therapy" } },
					{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "5-Day Christian Marriage Intensive" } },
					{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "3-to-5-Day Individual Intensive" } },
					{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Telehealth Therapy (North Carolina)" } }
				]
			},
			"sameAs": [
				"https://www.facebook.com/thekohlergroup",
				"https://www.instagram.com/thekohlergrouppllc/"
			]
		})} />
	</head>
	<body>
		<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-brand focus:text-white focus:px-4 focus:py-2 focus:rounded">Skip to content</a>
		<Nav />
		<main id="main-content">
			<slot />
		</main>
		<Footer />

		<!-- CTA click tracking (#50) -->
		<script is:inline>
			document.addEventListener('click', function(e) {
				var link = e.target.closest('a[href*="clientsecure.me"]');
				if (link && typeof gtag === 'function') {
					gtag('event', 'cta_click', {
						event_category: 'booking',
						event_label: link.textContent.trim(),
						transport_type: 'beacon'
					});
				}
			});
		</script>
	</body>
</html>
