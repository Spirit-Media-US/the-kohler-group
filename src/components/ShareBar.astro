---
interface Props {
	title: string;
	url: string;
}
const { title, url } = Astro.props;
const encoded = {
	url: encodeURIComponent(url),
	title: encodeURIComponent(title),
};
---

<section class="bg-white px-6 pb-10 lg:px-8">
	<div class="mx-auto max-w-3xl">
		<div class="flex items-center gap-4 flex-wrap">
			<span class="text-xs font-semibold text-gray-500 uppercase tracking-caps shrink-0">Share this post</span>

			<a
				href={`https://www.facebook.com/sharer/sharer.php?u=${encoded.url}`}
				target="_blank" rel="noopener noreferrer"
				aria-label="Share on Facebook"
				class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-ui text-gray-700 hover:bg-gray-100 transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#1877F2]">
					<path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
				</svg>
				Facebook
			</a>

			<a
				href={`https://twitter.com/intent/tweet?url=${encoded.url}&text=${encoded.title}`}
				target="_blank" rel="noopener noreferrer"
				aria-label="Share on X"
				class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-ui text-gray-700 hover:bg-gray-100 transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 300 300" fill="currentColor">
					<path d="M178.57 127.15 290.27 0h-26.46l-97.03 110.38L89.34 0H0l117.13 166.93L0 300h26.46l102.4-116.59L194.66 300H284L178.57 127.15zm-36.26 41.26-11.87-16.61L36.16 19.54h40.68l76.17 106.66 11.87 16.61 99.05 138.65h-40.69l-80.93-113.25z"/>
				</svg>
				X
			</a>

			<a
				href={`https://www.linkedin.com/sharing/share-offsite/?url=${encoded.url}`}
				target="_blank" rel="noopener noreferrer"
				aria-label="Share on LinkedIn"
				class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-ui text-gray-700 hover:bg-gray-100 transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#0A66C2]">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
				LinkedIn
			</a>

			<button
				id="copy-link-btn"
				data-url={url}
				aria-label="Copy link"
				class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-ui text-gray-700 hover:bg-gray-100 transition-colors cursor-pointer"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
					<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
				</svg>
				<span id="copy-link-label">Copy link</span>
			</button>
		</div>
	</div>
</section>

<script>
	const btn = document.getElementById('copy-link-btn');
	const label = document.getElementById('copy-link-label');
	if (btn && label) {
		btn.addEventListener('click', () => {
			const url = btn.getAttribute('data-url') || window.location.href;
			navigator.clipboard.writeText(url).then(() => {
				label.textContent = 'Copied!';
				setTimeout(() => { label.textContent = 'Copy link'; }, 2000);
			});
		});
	}
</script>
