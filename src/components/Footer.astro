---
import { sanityClient, urlFor } from "../lib/sanity";
import MailtoLink from "./MailtoLink.astro";
const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{ logo, phone, email, facebook, instagram }`);
const year = new Date().getFullYear();
---

<footer class="bg-brand text-white">
	<div class="container py-14 text-center">
		<!-- Logo mark -->
		<div class="mb-6 flex justify-center">
			<a href="/">
				<img
					src={settings?.logo ? urlFor(settings.logo).width(300).url() : ""}
					alt="The Kohler Group PLLC"
					class="h-16 w-auto opacity-90"
					width="1416"
					height="921"
					loading="lazy"
				/>
			</a>
		</div>

		<!-- Contact info -->
		<div class="flex flex-wrap items-center justify-center gap-3 text-sm text-white">
			<span>Phone: <a href="tel:2527588636" class="transition hover:text-white">{settings?.phone}</a></span>
			<span class="text-white">|</span>
			<MailtoLink
				email={settings?.email}
				class="inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 px-4 py-1.5 text-xs font-medium text-white transition hover:bg-white/20 hover:text-white"
			>
				<svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25H4.5a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5H4.5a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
				</svg>
				Send Us an Email
			</MailtoLink>
		</div>

		<!-- Address -->
		<p class="mt-2 text-sm text-white">
			Huntersville Location: Daetwyler Plaza Building, 13420 Reese Blvd W, Huntersville, NC 28078
		</p>

		<!-- Service area -->
		<p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-white">
			We see clients in person at our Huntersville, NC location (North Charlotte) and offer
			Telehealth Services in North and South Carolina.
		</p>

		<!-- Legal links -->
		<div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-xs text-white">
			<a href="/privacy-policy" class="uppercase tracking-ui transition hover:text-white/80"
				>Privacy Policy</a
			>
			<span class="text-white">|</span>
			<a href="/nondiscrimination-notice" class="uppercase tracking-ui transition hover:text-white/80"
				>Nondiscrimination Notice</a
			>
			<span class="text-white">|</span>
			<a href="/public-health-info" class="uppercase tracking-ui transition hover:text-white/80"
				>Public Health Info</a
			>
		</div>

		<!-- Copyright -->
		<p class="mt-6 text-xs text-white">
			&copy; <span id="footer-year"></span> The Kohler Group, PLLC. All rights reserved. &bull; Powered by <a href="https://spiritmediapublishing.com" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;">Spirit Media</a>
		</p>
	</div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = new Date().getFullYear().toString();
</script>
