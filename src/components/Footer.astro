---
const year = new Date().getFullYear();
---

<footer class="bg-brand text-white">
	<div class="container py-14 text-center">
		<!-- Logo mark -->
		<div class="mb-6 flex justify-center">
			<a href="/">
				<img
					src="https://static.wixstatic.com/media/2e5b58_0ea5ab642e2342b6b2a5f7578fad42e1~mv2.png"
					alt="The Kohler Group PLLC"
					class="h-16 w-auto opacity-90"
					width="160"
					height="64"
				/>
			</a>
		</div>

		<!-- Contact info -->
		<p class="text-sm text-white/80">
			Phone:
			<a href="tel:2527588636" class="transition hover:text-white">252-758-8636</a>
			&nbsp;|&nbsp; Email:
			<a href="mailto:info@thekohlergroup.net" class="transition hover:text-white"
				>info@thekohlergroup.net</a
			>
		</p>

		<!-- Address -->
		<p class="mt-2 text-sm text-white/70">
			Huntersville Location: Daetwyler Plaza Building, 13420 Reese Blvd W, Huntersville, NC 28078
		</p>

		<!-- Service area -->
		<p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-white/70">
			We serve Eastern North Carolina through Telehealth Services and currently see clients in
			person at our Huntersville (North Charlotte) location.
		</p>

		<!-- Legal links -->
		<div class="mt-8 flex flex-wrap items-center justify-center gap-3 text-xs text-white/50">
			<a href="/privacy-policy" class="uppercase tracking-ui transition hover:text-white/80"
				>Privacy Policy</a
			>
			<span class="text-white/30">|</span>
			<a href="/aca-notices" class="uppercase tracking-ui transition hover:text-white/80"
				>ACA Notices</a
			>
			<span class="text-white/30">|</span>
			<a href="/public-health-info" class="uppercase tracking-ui transition hover:text-white/80"
				>Public Health Info</a
			>
		</div>

		<!-- Copyright -->
		<p class="mt-6 text-xs text-white/30">
			&copy; {year} The Kohler Group, PLLC. All rights reserved.
		</p>
	</div>
</footer>
