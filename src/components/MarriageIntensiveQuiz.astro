---
interface Props {
	barbaraEmail: string;
	bookingUrl: string;
	phone: string;
}
const { barbaraEmail, bookingUrl, phone } = Astro.props;
const phoneDigits = phone.replace(/[^0-9]/g, '');
---

<div
	class="som-quiz"
	data-barbara-user={barbaraEmail.split('@')[0]}
	data-barbara-domain={barbaraEmail.split('@')[1]}
	data-booking-url={bookingUrl}
	data-phone={phone}
	data-phone-digits={phoneDigits}
>
	<!-- Quiz Card -->
	<div class="som-quiz-card">
		<header class="text-center mb-2">
			<p class="som-serif text-3xl font-light" style="color:var(--som-sapphire-deep)">Marriage Intensive Screening</p>
			<p class="text-sm italic mt-1" style="color:var(--som-mid-gray)">Let's See If We're a Fit</p>
		</header>

		<p class="text-center text-sm mt-3 mb-6" style="color:var(--som-mid-gray)">
			This takes about 2 minutes. Your answers are private and used only to prepare for your consultation.
		</p>

		<!-- Progress indicator -->
		<div class="flex items-center justify-between text-[0.7rem] uppercase tracking-[0.18em] mb-1" style="color:var(--som-mid-gray)">
			<span data-q-counter>Question 1 of 8</span>
			<span data-q-pct>13%</span>
		</div>
		<div class="h-[3px] w-full mb-7" style="background:var(--som-light-gray)">
			<div class="h-full transition-all duration-300" style="width:13%; background:var(--som-gold)" data-q-bar></div>
		</div>

		<!-- All steps render in DOM, hidden until active. JS toggles .is-active. -->
		<form data-q-form novalidate>
			<!-- Q1 -->
			<div class="som-q is-active" data-step="1">
				<p class="som-q-h">Are you struggling in your marriage right now?</p>
				<div class="som-q-choices">
					<label><input type="radio" name="q1" value="A" /><span><strong>A</strong> Yes — we are in a real crisis</span></label>
					<label><input type="radio" name="q1" value="B" /><span><strong>B</strong> Yes — we are both miserable, but we are committed to working through our issues</span></label>
					<label><input type="radio" name="q1" value="C" /><span><strong>C</strong> Yes — we are talking about divorce because we don't see how we can fix this</span></label>
					<label><input type="radio" name="q1" value="D" /><span><strong>D</strong> Somewhat — things are strained but not in crisis</span></label>
					<label><input type="radio" name="q1" value="E" /><span><strong>E</strong> Not in crisis, but we want something deeper</span></label>
				</div>
			</div>

			<!-- Q2 -->
			<div class="som-q" data-step="2">
				<p class="som-q-h">On a scale of 1–10, how would you rate your marriage today?</p>
				<div class="text-center my-6">
					<div class="som-serif text-6xl font-light" style="color:var(--som-gold)" data-q2-display>5</div>
				</div>
				<input type="range" name="q2" min="1" max="10" value="5" class="som-range" />
				<div class="flex justify-between text-xs mt-2" style="color:var(--som-mid-gray)">
					<span>1 — In serious trouble</span>
					<span>10 — Great marriage</span>
				</div>
				<p class="text-center text-sm mt-4" style="color:var(--som-mid-gray)" data-q2-label>Some hope, but uncertain</p>
			</div>

			<!-- Q3 -->
			<div class="som-q" data-step="3">
				<p class="som-q-h">How many marriage counselors have you seen before?</p>
				<div class="som-q-choices">
					<label><input type="radio" name="q3" value="A" /><span><strong>A</strong> None — this would be our first</span></label>
					<label><input type="radio" name="q3" value="B" /><span><strong>B</strong> One</span></label>
					<label><input type="radio" name="q3" value="C" /><span><strong>C</strong> Two or three</span></label>
					<label><input type="radio" name="q3" value="D" /><span><strong>D</strong> More than three — and nothing has worked</span></label>
				</div>
			</div>

			<!-- Q4 -->
			<div class="som-q" data-step="4">
				<p class="som-q-h">How much hope do you have that your marriage can be good?</p>
				<div class="text-center my-6">
					<div class="som-serif text-6xl font-light" style="color:var(--som-gold)" data-q4-display>5</div>
				</div>
				<input type="range" name="q4" min="1" max="10" value="5" class="som-range" />
				<div class="flex justify-between text-xs mt-2" style="color:var(--som-mid-gray)">
					<span>1 — Almost none</span>
					<span>10 — I believe we can get there</span>
				</div>
				<p class="text-center text-sm mt-4" style="color:var(--som-mid-gray)" data-q4-label>Some hope, but uncertain</p>
			</div>

			<!-- Q5 -->
			<div class="som-q" data-step="5">
				<p class="som-q-h">Are you willing to travel to Huntersville, NC (North Charlotte) and commit to working on your marriage for 5 consecutive days?</p>
				<div class="som-q-choices">
					<label><input type="radio" name="q5" value="A" /><span><strong>A</strong> Yes — we are willing to travel</span></label>
					<label><input type="radio" name="q5" value="B" /><span><strong>B</strong> We are already local to the Charlotte / Lake Norman area</span></label>
					<label><input type="radio" name="q5" value="C" /><span><strong>C</strong> Maybe — I'd want to know more first</span></label>
					<label><input type="radio" name="q5" value="D" /><span><strong>D</strong> No — travel is not possible for us right now</span></label>
				</div>
			</div>

			<!-- Q6 -->
			<div class="som-q" data-step="6">
				<p class="som-q-h">Are you willing to learn new things and try approaches you haven't tried before?</p>
				<div class="som-q-choices">
					<label><input type="radio" name="q6" value="A" /><span><strong>A</strong> Yes — we are open to whatever it takes</span></label>
					<label><input type="radio" name="q6" value="B" /><span><strong>B</strong> Mostly — I have some reservations but I'm willing</span></label>
					<label><input type="radio" name="q6" value="C" /><span><strong>C</strong> I'd need to understand what's involved first</span></label>
				</div>
			</div>

			<!-- Q7 -->
			<div class="som-q" data-step="7">
				<p class="som-q-h">Would you like a complimentary 30-minute consultation with Barbara to see if this is the right fit?</p>
				<div class="som-q-choices">
					<label><input type="radio" name="q7" value="A" /><span><strong>A</strong> Yes — I'd love that</span></label>
					<label><input type="radio" name="q7" value="B" /><span><strong>B</strong> I want a bit more information first</span></label>
					<label><input type="radio" name="q7" value="C" /><span><strong>C</strong> No, I'm not ready at this time</span></label>
				</div>
			</div>

			<!-- Q8 -->
			<div class="som-q" data-step="8">
				<p class="som-q-h">One last step — please complete the form below so Barbara's team can reach you.</p>
				<p class="text-sm mt-2 mb-6" style="color:var(--som-mid-gray)">
					Your information is private and used only to prepare for your consultation. You will receive a confirmation email with scheduling options.
				</p>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<label class="som-field sm:col-span-2"><span>Your Name</span><input type="text" name="name" required autocomplete="name" /></label>
					<label class="som-field"><span>Email</span><input type="email" name="email" required autocomplete="email" /></label>
					<label class="som-field"><span>Phone</span><input type="tel" name="phone" required autocomplete="tel" /></label>
					<label class="som-field sm:col-span-2"><span>Anything you'd like Barbara to know? <em class="opacity-70">(optional)</em></span><textarea name="note" rows="3"></textarea></label>
				</div>
			</div>

			<!-- Nav -->
			<div class="flex items-center justify-between mt-8">
				<button type="button" class="som-nav-back" data-q-back>← Back</button>
				<button type="button" class="som-btn-sapphire" data-q-next>Continue →</button>
				<button type="submit" class="som-btn-sapphire hidden" data-q-submit>Request My Consult →</button>
			</div>
		</form>
	</div>

	<!-- ===== OUTCOME: Qualified — "Great Fit" ===== -->
	<div class="som-outcome hidden" data-outcome="qualified">
		<div class="text-center">
			<div class="som-divider mb-3" aria-hidden="true">✦</div>
			<p class="som-serif text-4xl sm:text-5xl font-light" style="color:var(--som-sapphire-deep)">
				You Sound Like a <span class="som-italic-gold">Great Fit.</span>
			</p>
			<p class="text-base leading-relaxed mt-6 max-w-2xl mx-auto" style="color:var(--som-mid-gray)">
				Based on your answers, the Marriage Intensive may be exactly what you and your spouse need. Barbara would love to connect with you for a complimentary 30-minute consultation — no obligation, no pressure. Just a real conversation.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-10">
				<a href={bookingUrl} target="_blank" rel="noopener" class="som-btn-gold">Schedule Your Free Consult</a>
				<a href={`tel:${phoneDigits}`} class="som-btn-outline">Or call: {phone}</a>
			</div>
			<p class="text-xs mt-6" style="color:var(--som-mid-gray)">
				A confirmation email has been sent to Barbara's office with your responses.
			</p>
		</div>
	</div>

	<!-- ===== OUTCOME: We Completely Understand (Q7=C — not ready) ===== -->
	<div class="som-outcome hidden" data-outcome="not-ready">
		<div class="text-center">
			<div class="som-divider mb-3" aria-hidden="true">†</div>
			<p class="som-serif text-4xl sm:text-5xl font-light" style="color:var(--som-sapphire-deep)">
				We Completely <span class="som-italic-gold">Understand.</span>
			</p>
			<p class="text-base leading-relaxed mt-6 max-w-2xl mx-auto" style="color:var(--som-mid-gray)">
				Not everyone is ready at the same moment — and that's okay. What would be most helpful for you right now?
			</p>
			<div class="flex flex-col gap-3 max-w-md mx-auto mt-10">
				<button type="button" class="som-soft-btn" data-go="individual">
					<strong>A</strong> Learn about Barbara's Individual Psychotherapy &amp; Personal Growth Intensives
				</button>
				<button type="button" class="som-soft-btn" data-go="phone-only">
					<strong>B</strong> Call when I'm ready — just give me the number
				</button>
			</div>
		</div>
	</div>

	<!-- ===== OUTCOME: Individual Intensive Inquiry (sub-form) ===== -->
	<div class="som-outcome hidden" data-outcome="individual">
		<div>
			<div class="text-center">
				<div class="som-divider mb-3" aria-hidden="true">✦</div>
				<p class="som-serif text-4xl font-light" style="color:var(--som-sapphire-deep)">
					Individual Intensive <span class="som-italic-gold">Inquiry</span>
				</p>
				<p class="text-base leading-relaxed mt-6 max-w-2xl mx-auto" style="color:var(--som-mid-gray)">
					Barbara's Individual Psychotherapy &amp; Personal Growth Intensives offer the same powerful, multidimensional approach — focused on you as an individual. Complete the form below and Barbara's team will be in touch.
				</p>
			</div>
			<form class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl mx-auto mt-10" data-individual-form novalidate>
				<label class="som-field sm:col-span-2"><span>Your Name</span><input type="text" name="name" required autocomplete="name" /></label>
				<label class="som-field"><span>Email</span><input type="email" name="email" required autocomplete="email" /></label>
				<label class="som-field"><span>Phone</span><input type="tel" name="phone" required autocomplete="tel" /></label>
				<label class="som-field sm:col-span-2"><span>What would you like Barbara to know?</span><textarea name="note" rows="3"></textarea></label>
				<div class="sm:col-span-2 flex items-center justify-between">
					<button type="button" class="som-nav-back" data-go-back>← Go Back</button>
					<button type="submit" class="som-btn-sapphire">Submit Individual Intensive Inquiry →</button>
				</div>
			</form>
		</div>
	</div>

	<!-- ===== OUTCOME: Thank You (after individual submit) ===== -->
	<div class="som-outcome hidden" data-outcome="thank-you">
		<div class="text-center">
			<div class="som-divider mb-3" aria-hidden="true">✦</div>
			<p class="som-serif text-4xl sm:text-5xl font-light" style="color:var(--som-sapphire-deep)">
				Thank <span class="som-italic-gold">You!</span>
			</p>
			<p class="text-base leading-relaxed mt-6 max-w-2xl mx-auto" style="color:var(--som-mid-gray)">
				We've received your Individual Intensive inquiry. Barbara's team will be in touch soon to share more information and explore whether this is a good fit for you.
			</p>
			<div class="mt-10">
				<a href="https://thekohlergroup.net" class="som-btn-outline">Visit TheKohlerGroup.net</a>
			</div>
		</div>
	</div>

	<!-- ===== OUTCOME: Sounds Good — phone only ===== -->
	<div class="som-outcome hidden" data-outcome="phone-only">
		<div class="text-center">
			<div class="som-divider mb-3" aria-hidden="true">†</div>
			<p class="som-serif text-4xl sm:text-5xl font-light" style="color:var(--som-sapphire-deep)">
				Sounds <span class="som-italic-gold">Good!</span>
			</p>
			<p class="text-base leading-relaxed mt-6 max-w-2xl mx-auto" style="color:var(--som-mid-gray)">
				Call us when you would like to explore services. We will be here when you are ready.
			</p>
			<a href={`tel:${phoneDigits}`} class="som-serif text-4xl sm:text-5xl mt-6 inline-block font-light" style="color:var(--som-gold)">{phone}</a>
			<p class="text-sm mt-4" style="color:var(--som-mid-gray)">The Kohler Group, PLLC · Huntersville, NC</p>
			<button type="button" class="som-nav-back mt-10" data-go-back>← Go Back</button>
		</div>
	</div>

	<!-- ===== OUTCOME: We Understand (Q5=D — travel impossible) ===== -->
	<div class="som-outcome hidden" data-outcome="travel-impossible">
		<div class="text-center">
			<div class="som-divider mb-3" aria-hidden="true">†</div>
			<p class="som-serif text-4xl sm:text-5xl font-light" style="color:var(--som-sapphire-deep)">
				We <span class="som-italic-gold">Understand.</span>
			</p>
			<p class="text-base leading-relaxed mt-6 max-w-2xl mx-auto" style="color:var(--som-mid-gray)">
				The Marriage Intensive is a significant commitment — and it's not right for everyone at every moment. If you'd like to learn more or explore whether this might become an option for you, we'd welcome a conversation when you're ready.
			</p>
			<div class="mt-10">
				<a href="https://thekohlergroup.net" class="som-btn-outline">Learn More at TheKohlerGroup.net</a>
			</div>
		</div>
	</div>
</div>

<style is:global>
	body.som-page .som-quiz-card {
		background: var(--som-warm-white);
		border: 1px solid var(--som-light-gray);
		padding: 2rem 1.5rem;
	}
	@media (min-width: 640px) {
		body.som-page .som-quiz-card { padding: 2.5rem 3rem; }
	}
	body.som-page .som-q { display: none; }
	body.som-page .som-q.is-active { display: block; animation: somFadeIn .25s ease; }
	@keyframes somFadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

	body.som-page .som-q-h {
		font-family: 'Cormorant Garamond', Georgia, serif;
		font-size: 1.6rem;
		font-weight: 500;
		line-height: 1.3;
		color: var(--som-sapphire-deep);
	}
	body.som-page .som-q-choices { display: grid; gap: 0.65rem; margin-top: 1.25rem; }
	body.som-page .som-q-choices label {
		display: flex; align-items: flex-start; gap: 0.85rem;
		padding: 0.95rem 1.05rem;
		background: #fff;
		border: 1px solid var(--som-light-gray);
		cursor: pointer;
		transition: border-color .15s ease, background .15s ease;
	}
	body.som-page .som-q-choices label:hover { border-color: var(--som-gold); }
	body.som-page .som-q-choices input[type="radio"] {
		margin-top: 0.25rem;
		accent-color: var(--som-gold);
		flex-shrink: 0;
	}
	body.som-page .som-q-choices label > span {
		font-size: 0.92rem;
		line-height: 1.5;
		color: var(--som-text);
	}
	body.som-page .som-q-choices label strong {
		display: inline-block;
		min-width: 1.2em;
		margin-right: 0.4em;
		font-weight: 600;
		color: var(--som-gold);
	}
	body.som-page .som-q-choices label.checked {
		border-color: var(--som-gold);
		background: rgba(184,150,62,0.05);
	}

	body.som-page .som-range {
		-webkit-appearance: none; appearance: none;
		width: 100%; height: 4px;
		background: var(--som-light-gray);
		outline: none;
	}
	body.som-page .som-range::-webkit-slider-thumb {
		-webkit-appearance: none; appearance: none;
		width: 22px; height: 22px;
		border-radius: 50%;
		background: var(--som-gold);
		cursor: pointer;
		border: 2px solid #fff;
		box-shadow: 0 1px 4px rgba(0,0,0,0.18);
	}
	body.som-page .som-range::-moz-range-thumb {
		width: 22px; height: 22px;
		border-radius: 50%;
		background: var(--som-gold);
		cursor: pointer;
		border: 2px solid #fff;
		box-shadow: 0 1px 4px rgba(0,0,0,0.18);
	}

	body.som-page .som-field { display: block; }
	body.som-page .som-field > span {
		display: block;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--som-mid-gray);
		margin-bottom: 0.4rem;
	}
	body.som-page .som-field input,
	body.som-page .som-field textarea {
		width: 100%;
		padding: 0.75rem 0.9rem;
		font-family: 'Montserrat', system-ui, sans-serif;
		font-size: 0.95rem;
		color: var(--som-text);
		background: #fff;
		border: 1px solid var(--som-light-gray);
		outline: none;
		transition: border-color .15s ease;
	}
	body.som-page .som-field input:focus,
	body.som-page .som-field textarea:focus {
		border-color: var(--som-gold);
	}
	body.som-page .som-field input.invalid,
	body.som-page .som-field textarea.invalid { border-color: #c0392b; }

	body.som-page .som-nav-back {
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--som-mid-gray);
		background: transparent;
		border: 0;
		cursor: pointer;
		padding: 0.85rem 0;
	}
	body.som-page .som-nav-back:hover { color: var(--som-sapphire-deep); }
	body.som-page .som-nav-back:disabled { opacity: 0.35; cursor: not-allowed; }

	body.som-page .som-soft-btn {
		display: block;
		text-align: left;
		background: #fff;
		border: 1px solid var(--som-light-gray);
		padding: 1rem 1.25rem;
		font-size: 0.95rem;
		line-height: 1.5;
		color: var(--som-text);
		cursor: pointer;
		transition: border-color .15s ease;
		font-family: inherit;
	}
	body.som-page .som-soft-btn:hover { border-color: var(--som-gold); }
	body.som-page .som-soft-btn strong {
		display: inline-block;
		font-weight: 600;
		color: var(--som-gold);
		margin-right: 0.5em;
	}
	body.som-page .som-outcome {
		background: var(--som-warm-white);
		border: 1px solid var(--som-light-gray);
		padding: 2.25rem 1.5rem;
	}
	@media (min-width: 640px) {
		body.som-page .som-outcome { padding: 3rem; }
	}
</style>

<script>
	type Answers = Record<string, string>;

	function initQuiz(root: HTMLElement) {
		const form = root.querySelector<HTMLFormElement>('[data-q-form]');
		const back = root.querySelector<HTMLButtonElement>('[data-q-back]');
		const next = root.querySelector<HTMLButtonElement>('[data-q-next]');
		const submit = root.querySelector<HTMLButtonElement>('[data-q-submit]');
		const counter = root.querySelector<HTMLElement>('[data-q-counter]');
		const pct = root.querySelector<HTMLElement>('[data-q-pct]');
		const bar = root.querySelector<HTMLElement>('[data-q-bar]');
		const card = root.querySelector<HTMLElement>('.som-quiz-card');
		if (!form || !back || !next || !submit || !counter || !pct || !bar || !card) return;

		const TOTAL = 8;
		let step = 1;

		const labelFor = (n: number) => {
			if (n <= 2) return 'In serious trouble';
			if (n <= 4) return 'Struggling but still here';
			if (n <= 6) return 'Some hope, but uncertain';
			if (n <= 8) return 'Doing well — and growing';
			return 'Strong and thriving';
		};
		const labelForHope = (n: number) => {
			if (n <= 2) return 'Almost no hope';
			if (n <= 4) return 'A flicker of hope';
			if (n <= 6) return 'Some hope, but uncertain';
			if (n <= 8) return 'Real, growing hope';
			return 'Confident we can get there';
		};

		// Live-update slider labels
		const q2 = form.querySelector<HTMLInputElement>('input[name="q2"]');
		const q2d = root.querySelector<HTMLElement>('[data-q2-display]');
		const q2l = root.querySelector<HTMLElement>('[data-q2-label]');
		q2?.addEventListener('input', () => {
			if (q2d) q2d.textContent = q2.value;
			if (q2l) q2l.textContent = labelFor(parseInt(q2.value, 10));
		});
		const q4 = form.querySelector<HTMLInputElement>('input[name="q4"]');
		const q4d = root.querySelector<HTMLElement>('[data-q4-display]');
		const q4l = root.querySelector<HTMLElement>('[data-q4-label]');
		q4?.addEventListener('input', () => {
			if (q4d) q4d.textContent = q4.value;
			if (q4l) q4l.textContent = labelForHope(parseInt(q4.value, 10));
		});

		// Click highlight on radio cards
		root.querySelectorAll<HTMLLabelElement>('.som-q-choices label').forEach((lab) => {
			lab.addEventListener('click', () => {
				const name = lab.querySelector<HTMLInputElement>('input[type="radio"]')?.name;
				if (!name) return;
				root.querySelectorAll<HTMLLabelElement>(`.som-q-choices input[name="${name}"]`).forEach((el) => {
					el.parentElement?.classList.remove('checked');
				});
				lab.classList.add('checked');
			});
		});

		const showStep = (n: number) => {
			step = n;
			root.querySelectorAll<HTMLElement>('.som-q').forEach((el) => {
				el.classList.toggle('is-active', parseInt(el.dataset.step ?? '0', 10) === n);
			});
			counter!.textContent = `Question ${n} of ${TOTAL}`;
			const p = Math.round((n / TOTAL) * 100);
			pct!.textContent = `${p}%`;
			bar!.style.width = `${p}%`;
			back!.disabled = n === 1;
			const isLast = n === TOTAL;
			next!.classList.toggle('hidden', isLast);
			submit!.classList.toggle('hidden', !isLast);
		};

		const validateStep = (n: number): boolean => {
			if (n === 8) {
				const name = form.querySelector<HTMLInputElement>('input[name="name"]');
				const email = form.querySelector<HTMLInputElement>('input[name="email"]');
				const phone = form.querySelector<HTMLInputElement>('input[name="phone"]');
				let ok = true;
				[name, email, phone].forEach((el) => {
					if (!el) return;
					const v = el.value.trim();
					const valid = v.length > 0 && (el.type !== 'email' || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v));
					el.classList.toggle('invalid', !valid);
					if (!valid) ok = false;
				});
				return ok;
			}
			if (n === 2 || n === 4) return true;
			const radios = form.querySelectorAll<HTMLInputElement>(`input[name="q${n}"]`);
			return Array.from(radios).some((r) => r.checked);
		};

		next.addEventListener('click', () => {
			if (!validateStep(step)) {
				const active = root.querySelector<HTMLElement>('.som-q.is-active');
				const help = active?.querySelector<HTMLElement>('.som-q-error');
				if (!help && active) {
					const note = document.createElement('p');
					note.className = 'som-q-error';
					note.style.cssText = 'color:#c0392b;font-size:0.85rem;margin-top:0.75rem';
					note.textContent = 'Please choose an answer to continue.';
					active.appendChild(note);
				}
				return;
			}
			root.querySelectorAll('.som-q-error').forEach((el) => el.remove());
			if (step < TOTAL) showStep(step + 1);
		});

		back.addEventListener('click', () => {
			if (step > 1) showStep(step - 1);
		});

		const collectAnswers = (): Answers => {
			const data = new FormData(form);
			const a: Answers = {};
			for (let i = 1; i <= 8; i++) {
				const v = data.get(`q${i}`);
				if (v != null) a[`q${i}`] = String(v);
			}
			a.name = String(data.get('name') ?? '');
			a.email = String(data.get('email') ?? '');
			a.phone = String(data.get('phone') ?? '');
			a.note = String(data.get('note') ?? '');
			return a;
		};

		const decideOutcome = (a: Answers): string => {
			if (a.q5 === 'D') return 'travel-impossible';
			if (a.q7 === 'C') return 'not-ready';
			return 'qualified';
		};

		const showOutcome = (key: string) => {
			card.classList.add('hidden');
			root.querySelectorAll<HTMLElement>('.som-outcome').forEach((el) => el.classList.add('hidden'));
			const target = root.querySelector<HTMLElement>(`[data-outcome="${key}"]`);
			if (target) {
				target.classList.remove('hidden');
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		};

		const friendlyAnswer = (q: string, v: string): string => {
			const map: Record<string, Record<string, string>> = {
				q1: {
					A: 'In real crisis',
					B: 'Both miserable but committed',
					C: 'Talking about divorce',
					D: 'Strained but not in crisis',
					E: 'Not in crisis — want something deeper',
				},
				q3: { A: 'None', B: 'One', C: 'Two or three', D: 'More than three' },
				q5: {
					A: 'Willing to travel',
					B: 'Local to Charlotte / Lake Norman',
					C: 'Maybe — wants more info',
					D: 'Travel not possible',
				},
				q6: { A: 'Open to whatever it takes', B: 'Mostly willing', C: 'Wants to understand first' },
				q7: { A: 'Yes — would love that', B: 'Wants more info first', C: 'Not ready right now' },
			};
			return map[q]?.[v] ?? v;
		};

		const buildMailto = (
			to: string,
			subject: string,
			a: Answers,
			kind: 'screening' | 'individual',
		): string => {
			const lines: string[] = [];
			lines.push(`From: ${a.name || '(no name)'}`);
			lines.push(`Email: ${a.email || '(no email)'}`);
			lines.push(`Phone: ${a.phone || '(no phone)'}`);
			lines.push('');
			if (kind === 'screening') {
				lines.push('--- Marriage Intensive Screening ---');
				if (a.q1) lines.push(`1. Struggling now: ${friendlyAnswer('q1', a.q1)}`);
				if (a.q2) lines.push(`2. Marriage rating today: ${a.q2}/10`);
				if (a.q3) lines.push(`3. Counselors seen before: ${friendlyAnswer('q3', a.q3)}`);
				if (a.q4) lines.push(`4. Hope level: ${a.q4}/10`);
				if (a.q5) lines.push(`5. Travel to Huntersville: ${friendlyAnswer('q5', a.q5)}`);
				if (a.q6) lines.push(`6. Open to new approaches: ${friendlyAnswer('q6', a.q6)}`);
				if (a.q7) lines.push(`7. Wants free 30-min consult: ${friendlyAnswer('q7', a.q7)}`);
			} else {
				lines.push('--- Individual Intensive Inquiry ---');
				lines.push('Source: /save-our-marriage screening (Q7 = not ready, chose individual track)');
			}
			if (a.note) {
				lines.push('');
				lines.push('Notes from prospect:');
				lines.push(a.note);
			}
			lines.push('');
			lines.push('---');
			lines.push('Submitted from saveourmarriage.us / thekohlergroup.net/save-our-marriage');
			const body = lines.join('\n');
			return `mailto:${to}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
		};

		const buildBarbaraEmail = () => {
			const u = root.dataset.barbaraUser;
			const d = root.dataset.barbaraDomain;
			return `${u}@${d}`;
		};

		// Submit primary screening form
		form.addEventListener('submit', (e) => {
			e.preventDefault();
			if (!validateStep(8)) return;
			const a = collectAnswers();
			const outcome = decideOutcome(a);
			const subject = `Marriage Intensive Inquiry — ${a.name || 'Prospect'}`;
			const mailto = buildMailto(buildBarbaraEmail(), subject, a, 'screening');
			window.location.href = mailto;
			// Show outcome regardless — mailto may not fire on some browsers; user can use schedule/call buttons
			setTimeout(() => showOutcome(outcome), 200);
		});

		// "We Completely Understand" sub-options
		root.querySelectorAll<HTMLButtonElement>('[data-go]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const target = btn.dataset.go!;
				showOutcome(target);
			});
		});

		// "Go Back" buttons inside outcome panels return to "Not Ready" hub
		root.querySelectorAll<HTMLButtonElement>('[data-go-back]').forEach((btn) => {
			btn.addEventListener('click', () => showOutcome('not-ready'));
		});

		// Individual Intensive form
		const indForm = root.querySelector<HTMLFormElement>('[data-individual-form]');
		indForm?.addEventListener('submit', (e) => {
			e.preventDefault();
			const data = new FormData(indForm);
			const a: Answers = {
				name: String(data.get('name') ?? ''),
				email: String(data.get('email') ?? ''),
				phone: String(data.get('phone') ?? ''),
				note: String(data.get('note') ?? ''),
			};
			let ok = true;
			indForm.querySelectorAll<HTMLInputElement>('input[required]').forEach((el) => {
				const v = el.value.trim();
				const valid = v.length > 0 && (el.type !== 'email' || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v));
				el.classList.toggle('invalid', !valid);
				if (!valid) ok = false;
			});
			if (!ok) return;
			const subject = `Individual Intensive Inquiry — ${a.name || 'Prospect'}`;
			window.location.href = buildMailto(buildBarbaraEmail(), subject, a, 'individual');
			setTimeout(() => showOutcome('thank-you'), 200);
		});

		// Initial render
		showStep(1);
	}

	function bootQuizzes() {
		document.querySelectorAll<HTMLElement>('.som-quiz').forEach(initQuiz);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', bootQuizzes);
	} else {
		bootQuizzes();
	}
</script>
