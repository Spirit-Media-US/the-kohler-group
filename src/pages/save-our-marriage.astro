---
import MarriageIntensiveQuiz from '@components/MarriageIntensiveQuiz.astro';
import Layout from '@layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{
  phone, email, barbaraEmail, officeEmail, bookingUrl,
  somVideoUrl, somHeroBackground, somBarbaraPhoto, somPrice
}`);

const testimonials = await sanityClient.fetch(`
  *[_type == "testimonial" && service == "Marriage Intensive"] | order(order asc) {
    _id, service, quote
  }
`);

const price = settings?.somPrice || '$15,000';

function toYouTubeEmbed(url: string | null | undefined): string | null {
	if (!url) return null;
	const m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]{11})/);
	return m ? `https://www.youtube.com/embed/${m[1]}` : url;
}
const videoUrl: string | null = toYouTubeEmbed(settings?.somVideoUrl);
const bookingUrl = settings?.bookingUrl || 'https://thekohlergroup.clientsecure.me';
const barbaraEmail = settings?.barbaraEmail || 'barbara@thekohlergroup.net';
const phone = settings?.phone || '704-948-1268';

const barbaraPhotoUrl = settings?.somBarbaraPhoto
	? urlFor(settings.somBarbaraPhoto)
			.width(800)
			.height(1067)
			.fit('crop')
			.format('webp')
			.quality(85)
			.url()
	: 'https://cdn.sanity.io/images/2bom5gqg/production/725180bdf0526e9efb4151d71422bddf9364d86c-2400x3000.jpg?w=800&h=1067&fit=crop&auto=format';

// Couple thumbnails strip — square crops, single row above "Who This Is For"
const coupleThumbs = [
	{
		url: 'https://cdn.sanity.io/images/2bom5gqg/production/79bc51e151e87d59cb1cc31823371b8bdbb30a63-4349x2903.jpg?w=600&h=600&fit=crop&auto=format',
		alt: 'Young married couple',
	},
	{
		url: 'https://cdn.sanity.io/images/2bom5gqg/production/b07cc51ec5056b213e5edd18319b685c8e22c321-6022x5464.jpg?w=600&h=600&fit=crop&auto=format',
		alt: 'Senior married couple',
	},
	{
		url: 'https://images.unsplash.com/photo-1776266099419-dde2d16f4df6?w=600&h=600&fit=crop&auto=format&q=80',
		alt: 'Married couple smiling at each other outdoors',
	},
	{
		url: 'https://images.unsplash.com/photo-1772419578685-f918fb5b814b?w=600&h=600&fit=crop&auto=format&q=80',
		alt: 'Middle-aged married couple together',
	},
];

const heroBgUrl = settings?.somHeroBackground
	? urlFor(settings.somHeroBackground).width(1920).format('webp').quality(80).url()
	: null;

const canonicalURL = 'https://thekohlergroup.net/save-our-marriage';
const ogImage = barbaraPhotoUrl;
---

<Layout
	title="Save Our Marriage | 5-Day Marriage Intensive — Barbara Kohler, LCMHC"
	description="Your marriage can be saved — but not with another hour of weekly counseling. A 5-day faith-integrated Marriage Intensive in Huntersville, NC with Barbara Kohler, LCMHC. Re-Decision Therapy, EMDR, HeartSync, TRET, and Judicial Prayer in concentrated, transformative work."
	canonicalURL={canonicalURL}
	ogImage={ogImage}
	landing={true}
>
	<Fragment slot="head">
		<link rel="preconnect" href="https://images.unsplash.com" crossorigin />
		<link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-400.woff2" crossorigin />
		<style is:inline>
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:300;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-300.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-400.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:500;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-500.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:600;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-600.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:italic;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-400-italic.woff2') format('woff2')}

			/* ======================================================================
			   Save Our Marriage — ported verbatim from Barbara's prototype CSS,
			   scoped under body.som-page so nothing leaks into the rest of TKG.
			   Wrapped in @layer base so Tailwind v4 utilities can still override
			   on the few elements where we mix classes.
			   ====================================================================== */
			@layer base {
				body.som-page {
					--som-sapphire: #1a4a8a;
					--som-sapphire-deep: #0f2d5a;
					--som-sapphire-light: #2a5fa8;
					--som-gold: #b8963e;
					--som-gold-light: #d4af6a;
					--som-cream: #faf7f2;
					--som-warm-white: #fff9f3;
					--som-charcoal: #1c1c1c;
					--som-mid-gray: #666;
					--som-light-gray: #e8e4de;
					--som-text: #2d2d2d;
					font-family: 'Montserrat', system-ui, sans-serif;
					color: var(--som-text);
					background: var(--som-warm-white);
					overflow-x: hidden;
				}

				/* ─── HERO ─── */
				body.som-page .som-hero {
					min-height: 100vh;
					background: linear-gradient(160deg, var(--som-sapphire-deep) 0%, var(--som-sapphire) 50%, #1e3a6e 100%);
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: center;
					text-align: center;
					padding: 80px 24px 60px;
					position: relative;
					overflow: hidden;
				}
				body.som-page .som-hero-grid {
					position: relative;
					z-index: 2;
					width: 100%;
					max-width: 1200px;
					margin: 0 auto;
					display: grid;
					grid-template-columns: 2fr 3fr;
					gap: 60px;
					align-items: start;
				}
				body.som-page .som-hero-body-full {
					position: relative;
					z-index: 2;
					width: 100%;
					max-width: 1200px;
					margin: 56px auto 0;
				}
				@media (max-width: 1024px) {
					body.som-page .som-hero-grid {
						grid-template-columns: 1fr;
						gap: 40px;
					}
				}
				body.som-page .som-hero-text { text-align: left; }
				body.som-page .som-hero-text .som-hero-divider { margin: 0 0 32px 0; }
				body.som-page .som-hero-text .som-hero-body { max-width: 100%; margin: 0; }
				body.som-page .som-hero-media {
					display: flex;
					flex-direction: column;
					gap: 28px;
					align-items: stretch;
				}
				body.som-page .som-hero-video {
					width: 100%;
					aspect-ratio: 16/9;
					background: var(--som-sapphire-deep);
					position: relative;
					overflow: hidden;
					box-shadow: 0 20px 60px rgba(0,0,0,0.4);
				}
				body.som-page .som-hero-video iframe {
					position: absolute;
					inset: 0;
					width: 100%;
					height: 100%;
					border: 0;
				}
				body.som-page .som-hero-video--placeholder {
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: center;
					color: rgba(255,255,255,0.5);
				}
				body.som-page .som-hero-video--placeholder::before {
					content: '';
					position: absolute;
					inset: 0;
					background: linear-gradient(135deg, rgba(184,150,62,0.10) 0%, transparent 60%);
				}
				body.som-page .som-hero-video--placeholder p {
					font-size: 13px;
					letter-spacing: 2px;
					text-transform: uppercase;
					position: relative;
					z-index: 2;
				}
				body.som-page .som-hero-cta {
					display: flex;
					justify-content: center;
				}
				body.som-page .som-hero::before {
					content: '';
					position: absolute;
					inset: 0;
					background:
						radial-gradient(ellipse at 30% 20%, rgba(184,150,62,0.15) 0%, transparent 60%),
						radial-gradient(ellipse at 70% 80%, rgba(255,255,255,0.05) 0%, transparent 50%);
					z-index: 0;
				}
				body.som-page .som-hero.has-bg::after {
					content: '';
					position: absolute;
					inset: 0;
					background-image: var(--som-hero-bg);
					background-size: cover;
					background-position: center;
					opacity: 0.18;
					z-index: 0;
				}
				body.som-page .som-hero > * { position: relative; z-index: 2; }
				body.som-page .som-hero-cross {
					position: absolute;
					opacity: 0.04;
					font-size: 400px;
					color: #fff;
					top: 50%;
					left: 50%;
					transform: translate(-50%, -50%);
					user-select: none;
					line-height: 1;
					z-index: 1;
					font-family: 'Cormorant Garamond', Georgia, serif;
					pointer-events: none;
				}
				body.som-page .som-hero-eyebrow {
					font-size: 11px;
					font-weight: 600;
					letter-spacing: 4px;
					text-transform: uppercase;
					color: var(--som-gold-light);
					margin-bottom: 24px;
				}
				body.som-page .som-hero h1 {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: clamp(48px, 8vw, 96px);
					font-weight: 300;
					color: #fff;
					line-height: 1.05;
					margin-bottom: 8px;
				}
				body.som-page .som-hero h1 em {
					font-style: italic;
					color: var(--som-gold-light);
				}
				body.som-page .som-hero-subtitle {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: clamp(20px, 3vw, 28px);
					font-weight: 300;
					font-style: italic;
					color: rgba(255,255,255,0.78);
					margin-bottom: 40px;
				}
				body.som-page .som-hero-divider {
					width: 60px;
					height: 1px;
					background: var(--som-gold);
					margin: 0 auto 32px;
				}
				body.som-page .som-hero-body {
					font-size: 16px;
					font-weight: 300;
					color: rgba(255,255,255,0.82);
					max-width: 560px;
					line-height: 1.8;
					margin: 0 auto 48px;
				}
				body.som-page .som-btn-primary {
					background: var(--som-gold);
					color: #fff;
					font-size: 12px;
					font-weight: 600;
					letter-spacing: 2px;
					text-transform: uppercase;
					padding: 18px 40px;
					border: 0;
					cursor: pointer;
					text-decoration: none;
					display: inline-block;
					transition: background .3s ease, transform .2s ease;
				}
				body.som-page .som-btn-primary:hover {
					background: var(--som-gold-light);
					transform: translateY(-2px);
				}

				/* ─── SHARED SECTION ELEMENTS ─── */
				body.som-page .som-section-label {
					font-size: 11px;
					font-weight: 700;
					letter-spacing: 5px;
					text-transform: uppercase;
					color: var(--som-gold);
					margin-bottom: 16px;
				}
				body.som-page .som-section-title {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: clamp(36px, 5vw, 56px);
					font-weight: 400;
					color: var(--som-sapphire-deep);
					line-height: 1.15;
					margin-bottom: 24px;
				}
				body.som-page .som-section-title em { font-style: italic; color: var(--som-gold); }
				body.som-page .som-section-body {
					font-size: 15px;
					font-weight: 300;
					color: var(--som-mid-gray);
					max-width: 600px;
					margin: 0 auto 48px;
					line-height: 1.9;
				}
				body.som-page .som-container { max-width: 1100px; margin: 0 auto; }

				/* ─── VIDEO SECTION ─── */
				body.som-page .som-video-section {
					background: var(--som-cream);
					padding: 100px 24px;
					text-align: center;
				}
				body.som-page .som-video-placeholder {
					max-width: 800px;
					margin: 0 auto;
					background: var(--som-sapphire-deep);
					aspect-ratio: 16/9;
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: center;
					color: rgba(255,255,255,0.5);
					position: relative;
					overflow: hidden;
				}
				body.som-page .som-video-placeholder::before {
					content: '';
					position: absolute;
					inset: 0;
					background: linear-gradient(135deg, rgba(184,150,62,0.10) 0%, transparent 60%);
				}
				body.som-page .som-video-play-icon {
					width: 72px;
					height: 72px;
					border: 2px solid rgba(255,255,255,0.3);
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					margin-bottom: 16px;
					position: relative;
				}
				body.som-page .som-video-play-icon::after {
					content: '';
					border-style: solid;
					border-width: 12px 0 12px 22px;
					border-color: transparent transparent transparent rgba(255,255,255,0.6);
					margin-left: 6px;
				}
				body.som-page .som-video-placeholder p {
					font-size: 13px;
					letter-spacing: 2px;
					text-transform: uppercase;
					position: relative;
					z-index: 2;
				}
				body.som-page .som-video-iframe {
					max-width: 800px;
					margin: 0 auto;
					aspect-ratio: 16/9;
					overflow: hidden;
					position: relative;
				}
				body.som-page .som-video-iframe iframe {
					width: 100%;
					height: 100%;
					border: 0;
				}

				/* ─── TRUTH STRIP ─── */
				body.som-page .som-truth-strip {
					background: var(--som-sapphire-deep);
					padding: 70px 24px;
					text-align: center;
				}
				body.som-page .som-truth-strip blockquote {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: clamp(24px, 4vw, 44px);
					font-weight: 300;
					font-style: italic;
					color: #fff;
					max-width: 800px;
					margin: 0 auto;
					line-height: 1.4;
				}
				body.som-page .som-truth-strip cite {
					display: block;
					font-family: 'Montserrat', system-ui, sans-serif;
					font-size: 11px;
					font-weight: 600;
					letter-spacing: 3px;
					text-transform: uppercase;
					color: var(--som-gold-light);
					margin-top: 20px;
					font-style: normal;
				}

				/* ─── PILLARS (Why This Works) ─── */
				body.som-page .som-different-section {
					padding: 100px 24px;
					background: var(--som-warm-white);
				}
				body.som-page .som-section-header { text-align: center; margin-bottom: 70px; }
				body.som-page .som-pillars-grid {
					display: grid;
					grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
					gap: 2px;
					background: var(--som-light-gray);
				}
				body.som-page .som-pillar {
					background: var(--som-warm-white);
					padding: 48px 40px;
					position: relative;
					transition: background .3s ease;
				}
				body.som-page .som-pillar:hover { background: var(--som-cream); }
				body.som-page .som-pillar-number {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: 72px;
					font-weight: 400;
					color: var(--som-sapphire-light);
					line-height: 1;
					margin-bottom: 16px;
				}
				body.som-page .som-pillar-accent {
					width: 30px;
					height: 2px;
					background: var(--som-gold);
					margin-bottom: 20px;
				}
				body.som-page .som-pillar h3 {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: 24px;
					font-weight: 500;
					color: var(--som-sapphire-deep);
					margin-bottom: 14px;
					line-height: 1.2;
				}
				body.som-page .som-pillar p {
					font-size: 14px;
					font-weight: 300;
					color: var(--som-mid-gray);
					line-height: 1.8;
				}

				/* ─── COUPLE THUMBS STRIP ─── */
				body.som-page .som-couples-strip {
					background: var(--som-cream);
					padding: 0 0 0 0;
				}
				body.som-page .som-couples-grid {
					display: grid;
					grid-template-columns: repeat(4, 1fr);
					gap: 0;
				}
				body.som-page .som-couples-grid img {
					width: 100%;
					aspect-ratio: 1 / 1;
					object-fit: cover;
					display: block;
					filter: saturate(0.95);
					transition: filter .35s ease;
				}
				body.som-page .som-couples-grid img:hover { filter: saturate(1.1); }
				@media (max-width: 700px) {
					body.som-page .som-couples-grid { grid-template-columns: repeat(2, 1fr); }
				}

				/* ─── WHO THIS IS FOR ─── */
				body.som-page .som-who-section { background: var(--som-cream); padding: 100px 24px; }
				body.som-page .som-two-col {
					display: grid;
					grid-template-columns: 1fr 1fr;
					gap: 80px;
					align-items: start;
				}
				@media (max-width: 768px) { body.som-page .som-two-col { grid-template-columns: 1fr; gap: 48px; } }
				body.som-page .som-who-list {
					list-style: none;
					padding: 0;
					margin: 0;
					display: flex;
					flex-direction: column;
					gap: 24px;
				}
				body.som-page .som-who-list li {
					display: flex;
					gap: 20px;
					align-items: flex-start;
				}
				body.som-page .som-who-icon {
					width: 8px;
					height: 8px;
					background: var(--som-gold);
					border-radius: 50%;
					flex-shrink: 0;
					margin-top: 7px;
				}
				body.som-page .som-who-list li span {
					font-size: 15px;
					font-weight: 300;
					line-height: 1.7;
					color: var(--som-text);
				}
				body.som-page .som-stat-box {
					background: var(--som-sapphire-deep);
					color: #fff;
					padding: 48px 40px;
				}
				body.som-page .som-stat-box + .som-stat-box { margin-top: 24px; }
				body.som-page .som-stat-number {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: 72px;
					font-weight: 300;
					color: var(--som-gold-light);
					line-height: 1;
				}
				body.som-page .som-stat-label {
					font-size: 12px;
					font-weight: 600;
					letter-spacing: 2px;
					text-transform: uppercase;
					color: rgba(255,255,255,0.6);
					margin-top: 8px;
				}
				body.som-page .som-stat-caption {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: 18px;
					font-style: italic;
					font-weight: 300;
					color: rgba(255,255,255,0.78);
					margin-top: 16px;
					line-height: 1.7;
				}
				body.som-page .som-pull-quote {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-style: italic;
					font-weight: 300;
					font-size: clamp(20px, 2.5vw, 28px);
					color: var(--som-sapphire-deep);
					line-height: 1.5;
					max-width: 900px;
					margin: 64px auto 0;
					text-align: center;
				}

				/* ─── BARBARA BIO ─── */
				body.som-page .som-bio-section { padding: 100px 24px; background: var(--som-warm-white); }
				body.som-page .som-bio-inner {
					max-width: 900px;
					margin: 0 auto;
					display: grid;
					grid-template-columns: 1fr 2fr;
					gap: 70px;
					align-items: start;
				}
				@media (max-width: 700px) {
					body.som-page .som-bio-inner { grid-template-columns: 1fr; gap: 40px; }
				}
				body.som-page .som-bio-portrait {
					aspect-ratio: 3/4;
					width: 100%;
					object-fit: cover;
					display: block;
				}
				body.som-page .som-bio-name {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: 38px;
					font-weight: 400;
					color: var(--som-sapphire-deep);
					margin-bottom: 4px;
				}
				body.som-page .som-bio-licensure {
					font-size: 11px;
					font-weight: 600;
					letter-spacing: 2px;
					text-transform: uppercase;
					color: var(--som-mid-gray);
					margin-bottom: 18px;
				}
				body.som-page .som-bio-credentials {
					display: flex;
					gap: 8px;
					flex-wrap: wrap;
					margin-bottom: 24px;
				}
				body.som-page .som-cred-tag {
					font-size: 10px;
					font-weight: 700;
					letter-spacing: 2px;
					text-transform: uppercase;
					padding: 5px 12px;
					background: var(--som-sapphire-deep);
					color: #fff;
				}
				body.som-page .som-bio-text p {
					font-size: 15px;
					font-weight: 300;
					line-height: 1.9;
					color: var(--som-text);
					margin-bottom: 16px;
				}
				body.som-page .som-bio-text p:last-child { margin-bottom: 0; }

				/* ─── INVESTMENT ─── */
				body.som-page .som-investment-section {
					background: var(--som-sapphire-deep);
					padding: 100px 24px;
