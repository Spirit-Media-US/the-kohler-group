---
import MarriageIntensiveQuiz from '@components/MarriageIntensiveQuiz.astro';
import Layout from '@layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{
  phone, email, barbaraEmail, officeEmail, bookingUrl,
  somVideoUrl, somHeroBackground, somBarbaraPhoto, somPrice
}`);

// Defaults — used when Sanity fields are empty so the page never breaks
const price = settings?.somPrice || '$15,000';
const videoUrl: string | null = settings?.somVideoUrl || null;
const bookingUrl = settings?.bookingUrl || 'https://thekohlergroup.clientsecure.me';
const barbaraEmail = settings?.barbaraEmail || 'barbara@thekohlergroup.net';
const phone = settings?.phone || '704-948-1268';

// Barbara photo — Sanity-overridable, falls back to existing intensive portrait
const barbaraPhotoUrl = settings?.somBarbaraPhoto
	? urlFor(settings.somBarbaraPhoto)
			.width(800)
			.height(800)
			.fit('crop')
			.format('webp')
			.quality(85)
			.url()
	: 'https://cdn.sanity.io/images/2bom5gqg/production/21282e732035fa47572f5ca27d12ae838ef7fe43-600x400.jpg?w=800&h=800&fit=crop&auto=format';

// Optional hero background image — when set, sits behind a navy overlay
const heroBgUrl = settings?.somHeroBackground
	? urlFor(settings.somHeroBackground).width(1920).format('webp').quality(80).url()
	: null;

const canonicalURL = 'https://thekohlergroup.net/save-our-marriage';
const ogImage = barbaraPhotoUrl;
---

<Layout
	title="Save Our Marriage | 5-Day Marriage Intensive — Barbara Kohler, LCMHC"
	description="Your marriage can be saved — but not with another hour of weekly counseling. A 5-day faith-integrated Marriage Intensive in Huntersville, NC with Barbara Kohler, LCMHC. Re-Decision Therapy, EMDR, HeartSync, TRET, and Judicial Prayer in concentrated, transformative work."
	canonicalURL={canonicalURL}
	ogImage={ogImage}
	landing={true}
>
	<Fragment slot="head">
		<!-- Cormorant Garamond — self-hosted serif used only on this page -->
		<link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-400.woff2" crossorigin />
		<style is:inline>
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:300;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-300.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-400.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:500;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-500.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:600;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-600.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:italic;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-400-italic.woff2') format('woff2')}

			/* SOM design tokens — scoped to body.som-page so they never leak into the rest of TKG */
			@layer base {
				body.som-page {
					--som-sapphire: #1a4a8a;
					--som-sapphire-deep: #0f2d5a;
					--som-sapphire-light: #2a5fa8;
					--som-gold: #b8963e;
					--som-gold-light: #d4af6a;
					--som-cream: #faf7f2;
					--som-warm-white: #fff9f3;
					--som-charcoal: #1c1c1c;
					--som-mid-gray: #666;
					--som-light-gray: #e8e4de;
					--som-text: #2d2d2d;
					background: var(--som-warm-white);
					color: var(--som-text);
				}
				body.som-page .som-serif { font-family: 'Cormorant Garamond', Georgia, serif; }
				body.som-page .som-italic-gold { font-style: italic; color: var(--som-gold); }
				body.som-page .som-eyebrow {
					font-size: 0.7rem;
					font-weight: 600;
					letter-spacing: 0.25em;
					text-transform: uppercase;
					color: var(--som-gold);
				}
				body.som-page .som-eyebrow-light {
					color: var(--som-gold-light);
				}
				body.som-page .som-divider {
					color: var(--som-gold);
					font-size: 1.5rem;
					font-family: 'Cormorant Garamond', Georgia, serif;
				}
				body.som-page .som-btn-gold {
					display: inline-block;
					background: var(--som-gold);
					color: #fff;
					padding: 0.95rem 2rem;
					font-size: 0.78rem;
					font-weight: 600;
					letter-spacing: 0.18em;
					text-transform: uppercase;
					transition: background 0.18s ease;
				}
				body.som-page .som-btn-gold:hover { background: #a07f30; }
				body.som-page .som-btn-outline {
					display: inline-block;
					border: 1.5px solid var(--som-gold);
					color: var(--som-gold);
					padding: 0.95rem 2rem;
					font-size: 0.78rem;
					font-weight: 600;
					letter-spacing: 0.18em;
					text-transform: uppercase;
					transition: background 0.18s ease, color 0.18s ease;
				}
				body.som-page .som-btn-outline:hover { background: var(--som-gold); color: #fff; }
				body.som-page .som-btn-sapphire {
					display: inline-block;
					background: var(--som-sapphire-deep);
					color: #fff;
					padding: 0.85rem 1.75rem;
					font-size: 0.78rem;
					font-weight: 600;
					letter-spacing: 0.18em;
					text-transform: uppercase;
					transition: background 0.18s ease;
					cursor: pointer;
					border: 0;
				}
				body.som-page .som-btn-sapphire:hover { background: var(--som-sapphire); }
				body.som-page .som-btn-sapphire:disabled { opacity: 0.45; cursor: not-allowed; }

				body.som-page .som-card {
					background: #fff;
					border: 1px solid var(--som-light-gray);
					padding: 2.25rem 1.75rem;
				}
				body.som-page .som-card-num {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: 2.25rem;
					font-weight: 300;
					color: var(--som-gold);
					line-height: 1;
					margin-bottom: 1.25rem;
				}
				body.som-page .som-card h3 {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: 1.4rem;
					font-weight: 500;
					color: var(--som-sapphire-deep);
					margin-bottom: 0.85rem;
					line-height: 1.25;
				}
				body.som-page .som-card p {
					font-size: 0.92rem;
					line-height: 1.65;
					color: var(--som-mid-gray);
				}

				body.som-page .som-stat-num {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: 3.25rem;
					font-weight: 300;
					color: var(--som-gold);
					line-height: 1;
				}

				body.som-page .som-bullet::before {
					content: '✦';
					color: var(--som-gold);
					margin-right: 0.6rem;
					font-size: 0.7em;
					vertical-align: middle;
				}

				/* Hero — pure CSS gradient unless an image is set, no LCP image cost */
				body.som-page .som-hero {
					background: linear-gradient(135deg, #0a1f42 0%, #0f2d5a 45%, #1a4a8a 100%);
					color: #fff;
					position: relative;
					overflow: hidden;
				}
				body.som-page .som-hero.has-bg::before {
					content: '';
					position: absolute;
					inset: 0;
					background-image: var(--som-hero-bg);
					background-size: cover;
					background-position: center;
					opacity: 0.32;
					z-index: 0;
				}
				body.som-page .som-hero.has-bg::after {
					content: '';
					position: absolute;
					inset: 0;
					background: linear-gradient(135deg, rgba(10,31,66,0.7) 0%, rgba(15,45,90,0.85) 100%);
					z-index: 1;
				}
				body.som-page .som-hero > * { position: relative; z-index: 2; }
			}
		</style>

		<!-- JSON-LD: Service + Person -->
		<script is:inline type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Service",
					"name": "5-Day Marriage Intensive",
					"alternateName": "Save Our Marriage Intensive",
					"description": "A 5-day faith-integrated marriage intensive in Huntersville, NC, led by Barbara Kohler, LCMHC. Re-Decision Therapy, EMDR, HeartSync, TRET, and Judicial Prayer in concentrated, transformative work for couples.",
					"provider": {
						"@type": "LocalBusiness",
						"name": "The Kohler Group, PLLC",
						"url": "https://thekohlergroup.net",
						"telephone": "+1-704-948-1268",
						"address": {
							"@type": "PostalAddress",
							"streetAddress": "13420 Reese Blvd W, Daetwyler Plaza",
							"addressLocality": "Huntersville",
							"addressRegion": "NC",
							"postalCode": "28078",
							"addressCountry": "US"
						},
						"priceRange": "$$$$"
					},
					"areaServed": [
						{ "@type": "Country", "name": "United States" },
						{ "@type": "State", "name": "North Carolina" }
					],
					"serviceType": "Christian Marriage Intensive Program",
					"url": canonicalURL,
					"offers": {
						"@type": "Offer",
						"price": "15000",
						"priceCurrency": "USD",
						"availability": "https://schema.org/InStock",
						"url": canonicalURL
					}
				},
				{
					"@type": "Person",
					"name": "Barbara Kohler",
					"jobTitle": "Licensed Clinical Mental Health Counselor",
					"honorificSuffix": "MS, CRC, LCMHC, NCC",
					"hasCredential": [
						"Licensed Clinical Mental Health Counselor (LCMHC)",
						"National Certified Counselor (NCC)",
						"Certified Rehabilitation Counselor (CRC)",
						"Ordained Minister"
					],
					"worksFor": { "@type": "LocalBusiness", "name": "The Kohler Group, PLLC", "url": "https://thekohlergroup.net" },
					"image": barbaraPhotoUrl,
					"url": "https://thekohlergroup.net/our-therapists/barbara-j-kohler/"
				}
			]
		})} />
	</Fragment>

	<script is:inline>
		document.body.classList.add('som-page');
	</script>

	<!-- =============== HERO =============== -->
	<section
		class:list={["som-hero", "px-6", "lg:px-8", "py-20", "lg:py-28", heroBgUrl && "has-bg"]}
		style={heroBgUrl ? `--som-hero-bg: url('${heroBgUrl}')` : undefined}
	>
		<div class="mx-auto max-w-4xl text-center">
			<p class="som-eyebrow som-eyebrow-light text-[0.65rem]">
				Save Our Marriage · 5-Day Marriage Intensive · Barbara Kohler, LCMHC
			</p>
			<div class="som-divider mt-8 mb-2" aria-hidden="true">†</div>
			<p class="text-[0.7rem] uppercase tracking-[0.25em] text-white/70 mb-12">
				The Kohler Group, PLLC · Huntersville, NC
			</p>

			<h1 class="som-serif text-5xl sm:text-6xl lg:text-7xl font-light leading-[1.05] text-white">
				Your Marriage<br />
				Can Be <span class="som-italic-gold">Saved.</span>
			</h1>

			<p class="som-serif italic text-2xl sm:text-3xl text-white/85 mt-8 font-light">
				But not with another hour of weekly counseling.
			</p>

			<p class="text-base sm:text-lg leading-relaxed text-white/85 mt-10 max-w-2xl mx-auto">
				The 5-Day Marriage Intensive is for couples who are done drifting, done fighting, and ready — truly ready — to do something transformative. For couples who believe their marriage is worth everything it takes.
			</p>

			<div class="mt-12">
				<a href="#screening" class="som-btn-gold">Find Out If You Qualify</a>
			</div>

			<a href="#video" class="block mt-20 text-[0.7rem] uppercase tracking-[0.25em] text-white/60 hover:text-white/90 transition-colors">
				How This Works<br />
				<span class="text-2xl mt-2 block animate-bounce" aria-hidden="true">↓</span>
			</a>
		</div>
	</section>

	<!-- =============== VIDEO MESSAGE =============== -->
	<section id="video" class="px-6 lg:px-8 py-20 lg:py-28" style="background:var(--som-cream)">
		<div class="mx-auto max-w-4xl text-center">
			<p class="som-eyebrow">A Message from Barbara</p>
			<h2 class="som-serif text-4xl sm:text-5xl lg:text-6xl font-light leading-tight mt-6" style="color:var(--som-sapphire-deep)">
				Hear What's<br />
				<span class="som-italic-gold">Possible</span>
			</h2>
			<p class="text-base sm:text-lg leading-relaxed mt-8 max-w-2xl mx-auto" style="color:var(--som-mid-gray)">
				Before you read another word, watch this. Barbara will tell you in her own words what the Marriage Intensive is — and why it's unlike anything you've tried before.
			</p>

			<div class="mt-12">
				{videoUrl ? (
					<div class="aspect-video rounded-md overflow-hidden shadow-lg">
						<iframe
							src={videoUrl}
							title="A Message from Barbara"
							loading="lazy"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
							class="w-full h-full"
						></iframe>
					</div>
				) : (
					<div
						class="aspect-video flex flex-col items-center justify-center rounded-md shadow-lg"
						style="background:linear-gradient(135deg,#0f2d5a 0%,#1a4a8a 100%)"
						aria-label="Video coming soon"
					>
						<div
							class="w-20 h-20 rounded-full flex items-center justify-center mb-5"
							style="background:rgba(184,150,62,0.18); border:1.5px solid var(--som-gold-light)"
						>
							<svg width="32" height="32" viewBox="0 0 24 24" fill="var(--som-gold-light)" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
						</div>
						<p class="text-[0.7rem] uppercase tracking-[0.25em] text-white/70">Video Coming Soon</p>
					</div>
				)}
			</div>

			<div class="mt-16">
				<p class="som-serif italic text-2xl sm:text-3xl font-light leading-snug max-w-2xl mx-auto" style="color:var(--som-sapphire-deep)">
					"What God has joined together, let no man separate."
				</p>
				<p class="text-[0.7rem] uppercase tracking-[0.25em] mt-4" style="color:var(--som-gold)">
					Matthew 19:6 · NASB
				</p>
			</div>
		</div>
	</section>

	<!-- =============== WHY THIS WORKS =============== -->
	<section class="px-6 lg:px-8 py-20 lg:py-28" style="background:var(--som-warm-white); border-top:1px solid var(--som-light-gray)">
		<div class="mx-auto max-w-6xl">
			<div class="text-center mb-16">
				<p class="som-eyebrow">Why This Works</p>
				<h2 class="som-serif text-4xl sm:text-5xl font-light leading-tight mt-6" style="color:var(--som-sapphire-deep)">
					This Is Not Typical Marriage Therapy.<br />
					<span class="som-italic-gold">This Is Transformation.</span>
				</h2>
				<p class="text-base sm:text-lg leading-relaxed mt-8 max-w-3xl mx-auto" style="color:var(--som-mid-gray)">
					Most couples have been to counselors. Many have been to multiple counselors. What they haven't experienced is a clinical process that addresses the root — spiritually, neurologically, and emotionally — in concentrated, consecutive days of focused work.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style="background:var(--som-light-gray)">
				<div class="som-card">
					<div class="som-card-num">01</div>
					<h3>Five Consecutive Days of Focused Work</h3>
					<p>Weekly 50-minute sessions have a ceiling. Real change requires sustained time. Five uninterrupted days create the momentum and depth that months of weekly sessions rarely reach.</p>
				</div>
				<div class="som-card">
					<div class="som-card-num">02</div>
					<h3>Four Clinical Modalities Working Together</h3>
					<p>Re-Decision Therapy, EMDR, HeartSync, Judicial Prayer and TRET address your marriage on every level — the early decisions you made about yourself, the lies and/or trauma stored in the deepest parts of your psyche as well as your body, and the spiritual fragmentation that talk therapy cannot touch.</p>
				</div>
				<div class="som-card">
					<div class="som-card-num">03</div>
					<h3>Faith-Integrated &amp; Clinically Grounded</h3>
					<p>Barbara holds a Master's degree in Rehabilitation Counseling Studies which looks at the client holistically. She has been licensed as an LCMHC since 2002, and is an ordained minister. She brings 30 years of clinical excellence and the power of Christ-centered prayer into the same room — because healing requires a multidimensional approach.</p>
				</div>
				<div class="som-card">
					<div class="som-card-num">04</div>
					<h3>You Work on the Root, Not Just the Symptoms</h3>
					<p>Most couples fight about money, kids, and sex. But those aren't the real issues. The real issues are the early decisions each of you made about your worth, your safety, and what love looks like — formed long before you ever met.</p>
				</div>
				<div class="som-card">
					<div class="som-card-num">05</div>
					<h3>100% Client Satisfaction Reported</h3>
					<p>Our clients surveyed report being completely satisfied with their Marriage Intensive experience and 100% said they would recommend it to others.</p>
				</div>
				<div class="som-card">
					<div class="som-card-num">06</div>
					<h3>Couples Travel From Across the Country</h3>
					<p>Couples travel from across the Carolinas and the entire United States to work with Barbara. This is not local-only care — it is a nationally recognized specialized program you cannot find everywhere.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- =============== WHO THIS IS FOR =============== -->
	<section class="px-6 lg:px-8 py-20 lg:py-28" style="background:var(--som-cream)">
		<div class="mx-auto max-w-6xl">
			<div class="text-center mb-14">
				<p class="som-eyebrow">Who This Is For</p>
				<h2 class="som-serif text-4xl sm:text-5xl font-light leading-tight mt-6" style="color:var(--som-sapphire-deep)">
					You May Be Ready<br />
					<span class="som-italic-gold">If This Is You</span>
				</h2>
				<p class="text-base sm:text-lg leading-relaxed mt-8 max-w-3xl mx-auto" style="color:var(--som-mid-gray)">
					Couples arrive at the Marriage Intensive from different places. What they share is a willingness to stop surviving and start truly living together.
				</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">
				<ul class="lg:col-span-2 space-y-4 text-base leading-relaxed" style="color:var(--som-text)">
					<li class="som-bullet">You've been to counseling before — maybe multiple counselors — and you're still in the same place.</li>
					<li class="som-bullet">You've experienced betrayal, affair, or a devastating rupture you don't know how to heal.</li>
					<li class="som-bullet">You're on a slow drift and you recognize it — and you're ready to stop.</li>
					<li class="som-bullet">Your faith matters to you, and you want a counselor who takes that seriously — not just tolerates it.</li>
					<li class="som-bullet">You're willing to come to Huntersville, NC for five days and invest fully in the process.</li>
					<li class="som-bullet">You sense there's a depth of connection and freedom you haven't reached — and you want it.</li>
					<li class="som-bullet">You want to have a biblical marriage where you both experience walking as heirs together of the grace of life (1 Peter 3:7).</li>
				</ul>

				<div class="space-y-8 p-8" style="background:var(--som-sapphire-deep); color:#fff">
					<div>
						<div class="som-stat-num">18+</div>
						<p class="text-sm leading-relaxed mt-3 text-white/85">Years of Clinical Experience Working with Couples</p>
					</div>
					<div>
						<div class="som-stat-num">30+</div>
						<p class="text-sm leading-relaxed mt-3 text-white/85">Years of Experience Working in the Counseling Field, Including Business Executives, Entrepreneurs, and the Families Who Enable Them to Be Successful</p>
					</div>
					<div>
						<div class="som-stat-num">100%</div>
						<p class="text-sm leading-relaxed mt-3 text-white/85">Client Satisfaction Rate</p>
					</div>
				</div>
			</div>

			<blockquote class="som-serif italic text-xl sm:text-2xl leading-relaxed mt-16 max-w-4xl mx-auto text-center" style="color:var(--som-sapphire-deep)">
				"I have walked alongside couples carrying some of the heaviest things imaginable — betrayal, generational trauma, years of disconnection. And I have watched God move in those marriages in ways that were, honestly, remarkable."
			</blockquote>
		</div>
	</section>

	<!-- =============== BARBARA BIO =============== -->
	<section class="px-6 lg:px-8 py-20 lg:py-28" style="background:var(--som-warm-white)">
		<div class="mx-auto max-w-5xl">
			<p class="som-eyebrow text-center">Your Guide</p>
			<h2 class="som-serif text-4xl sm:text-5xl font-light leading-tight mt-6 text-center" style="color:var(--som-sapphire-deep)">
				Barbara Kohler
			</h2>

			<div class="flex flex-wrap justify-center gap-2 mt-6 mb-2">
				{['MS', 'CRC', 'LCMHC', 'NCC'].map((cred) => (
					<span class="text-[0.7rem] uppercase tracking-[0.18em] px-3 py-1 border" style="border-color:var(--som-gold); color:var(--som-gold)">{cred}</span>
				))}
			</div>
			<p class="text-center text-sm" style="color:var(--som-mid-gray)">
				Licensed Since 2002 · Ordained Minister
			</p>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-10 mt-12 items-start">
				<div class="md:col-span-1">
					<img
						src={barbaraPhotoUrl}
						alt="Barbara Kohler, MS, LCMHC — Founder, The Kohler Group, PLLC"
						width="800"
						height="800"
						loading="lazy"
						decoding="async"
						class="w-full aspect-square object-cover"
						style="border:1px solid var(--som-light-gray)"
					/>
				</div>
				<div class="md:col-span-2 space-y-5 text-base leading-relaxed" style="color:var(--som-text)">
					<p>
						Barbara Kohler is the Founder and CEO of The Kohler Group, PLLC — a faith-integrated Christian psychotherapy practice located in Huntersville, NC, serving the greater Charlotte and Lake Norman area, with in-person and telehealth across North and South Carolina.
					</p>
					<p>
						She has been a Licensed Clinical Mental Health Counselor since 2002 and holds National Certified Counselor credentials since 2009. She is also an ordained minister — a distinction that shapes every aspect of how she works with couples.
					</p>
					<p>
