---
import Layout from '@layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const testimonials = await sanityClient.fetch(`
  *[_type == "testimonial"] | order(order asc) {
    _id,
    service,
    quote,
    order
  }
`);
const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{
  phone, email, barbaraEmail, officeEmail, bookingUrl,
  facebook, instagram,
  heroImage, aboutHeroImage, defaultHeroImage, logo,
  galleryImages
}`);
---

<Layout
	title="Testimonials | Barbara Kohler — Christian Counseling Huntersville NC"
	description="Client experiences from Barbara Kohler's Christian counseling in Huntersville, NC. Marriage intensives and faith-based therapy near Charlotte."
	heroPreload="https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "The Kohler Group, PLLC",
			"url": "https://thekohlergroup.net",
			"aggregateRating": {
				"@type": "AggregateRating",
				"ratingValue": "5",
				"bestRating": "5",
				"ratingCount": String(testimonials.length),
				"reviewCount": String(testimonials.length)
			},
			"review": testimonials.slice(0, 5).map((t: any) => ({
				"@type": "Review",
				"reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
				"reviewBody": t.quote,
				"author": { "@type": "Person", "name": "Anonymous Client" },
				"itemReviewed": {
					"@type": "ProfessionalService",
					"name": t.service || "Christian Counseling"
				}
			}))
		})}></script>
	</Fragment>
	<!-- Hero -->
	<section
		class="relative flex h-[250px] items-center justify-center bg-cover bg-top bg-no-repeat"
		style="background-image: url('https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg')"
	>
		<div class="absolute inset-0 bg-brand/80"></div>
		<div class="container relative z-10 text-center">
			<h1 class="text-4xl font-bold uppercase tracking-caps text-white sm:text-5xl">
				Real Client Experiences
			</h1>
		</div>
	</section>

	<!-- Intro + Privacy Note -->
	<section class="bg-white py-16">
		<div class="container max-w-4xl text-center">
			<p class="mb-4 text-4xl font-semibold text-brand">What Our Clients Say</p>
			<h2 class="mb-6 text-3xl font-bold tracking-wide text-brand sm:text-4xl">Stories of Healing & Transformation</h2>
			<p class="mx-auto max-w-2xl text-sm italic leading-relaxed text-black">
				At The Kohler Group, PLLC, we
				respect our clients' privacy and uphold the highest professional and ethical standards. The
				feedback shared below comes directly from real client surveys. To protect confidentiality,
				client names and identifying details have been redacted. Every testimonial reflects genuine
				client experience and our continued commitment to excellence, discretion, and trust.
			</p>
		</div>
	</section>

	<!-- Photo Gallery Row 1 -->
	{settings?.galleryImages && settings.galleryImages.length > 0 && (
		<section class="bg-gray-50 py-4">
			<div class="container">
				<div class="grid grid-cols-2 gap-4 md:grid-cols-4">
					{settings.galleryImages.map((image, index) => (
						<div class="overflow-hidden rounded-lg">
							<img
								src={urlFor(image).width(468).height(311).fit("crop").url()}
								srcset={`${urlFor(image).width(234).height(156).fit("crop").url()} 234w, ${urlFor(image).width(468).height(311).fit("crop").url()} 468w`}
								sizes="(max-width: 768px) 50vw, 25vw"
								alt={image.alt || `The Kohler Group gallery image ${index + 1}`}
								class="h-52 w-full object-cover transition duration-500 hover:scale-105"
								width="468"
								height="311"
								loading="lazy"
							/>
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Testimonials Grid -->
	<section class="bg-white py-20">
		<div class="container">
			<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{
					testimonials.map(({ service, quote }) => (
						<blockquote class="flex flex-col rounded-lg border border-gray-100 bg-white p-8 shadow-sm transition hover:shadow-md">
							<!-- Service label -->
							<div class="mb-5 flex justify-center">
								<span class="rounded-full bg-brand/10 px-3 py-1 text-xs font-bold uppercase tracking-caps text-brand">
									{service}
								</span>
							</div>
							<!-- Quote -->
							<svg class="mb-3 h-6 w-6 flex-shrink-0 text-brand/20" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
								<path d="M10 8C6.686 8 4 10.686 4 14v10h10V14H7.333C7.333 11.791 8.791 10 10 10V8zm14 0c-3.314 0-6 2.686-6 6v10h10V14h-6.667C21.333 11.791 22.791 10 24 10V8z" />
							</svg>
							<p class="flex-1 text-sm leading-relaxed text-gray-700">{quote}</p>
							<div class="mt-6 flex gap-1">
								{[...Array(5)].map(() => (
									<svg class="h-4 w-4 text-brand" fill="currentColor" viewBox="0 0 20 20">
										<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
									</svg>
								))}
							</div>
						</blockquote>
					))
				}
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-white py-20">
		<div class="container text-center">
			<h2 class="text-3xl font-bold uppercase tracking-caps text-brand">
				Your Story Could Be Next
			</h2>
			<p class="mx-auto mt-6 max-w-xl text-base text-gray-600">
				We care about helping you heal. Take the first step today.
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a
					href={settings?.bookingUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="btn-primary"
				>
					Request an Appointment
				</a>
				<a
					href={`tel:${settings?.phone?.replace(/-/g, '')}`}
					class="inline-block border-2 border-brand px-8 py-3 text-xs font-bold uppercase tracking-ui text-brand transition hover:bg-brand hover:text-white"
				>
					Call {settings?.phone}
				</a>
			</div>
		</div>
	</section>
</Layout>