---
import MailtoLink from '@components/MailtoLink.astro';
import Layout from '@layouts/Layout.astro';
import {
	getIntensiveDaySchedules,
	getIntensiveStages,
	sanityClient,
	urlFor,
} from '../../lib/sanity.ts';

const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{
  phone, email, barbaraEmail, officeEmail, bookingUrl,
  facebook, instagram,
  heroImage, aboutHeroImage, defaultHeroImage, logo
}`);
const healingStages = await getIntensiveStages('marriage', 'healing');
const awarenessStages = await getIntensiveStages('marriage', 'awareness');
const preparationItems = await getIntensiveStages('marriage', 'preparation');
const daySchedules = await getIntensiveDaySchedules('marriage');

// Group sessions by dayLabel for template rendering
const dayGroups: { label: string; sessions: any[] }[] = [];
for (const s of daySchedules) {
	const existing = dayGroups.find((d) => d.label === s.dayLabel);
	if (existing) {
		existing.sessions.push(s);
	} else {
		dayGroups.push({ label: s.dayLabel, sessions: [s] });
	}
}
---

<Layout
	title="Christian Marriage Intensive | Barbara Kohler — Huntersville NC"
	description="5-day Christian marriage intensive with Barbara Kohler in Huntersville, NC. Faith-based couples therapy with Re-decision Therapy and HeartSync."
	heroPreload="https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg"
>
	<!-- JSON-LD Structured Data -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "Service",
				"name": "Christian Marriage Intensive",
				"description": "A 5-day faith-based marriage intensive combining clinical psychotherapy with Biblical principles, led by licensed Christian counselor Barbara Kohler in Huntersville, NC.",
				"provider": {
					"@type": "LocalBusiness",
					"name": "The Kohler Group, PLLC",
					"url": "https://thekohlergroup.net",
					"telephone": "+1-252-758-8636",
					"address": {
						"@type": "PostalAddress",
						"streetAddress": "13420 Reese Blvd W, Daetwyler Plaza Building",
						"addressLocality": "Huntersville",
						"addressRegion": "NC",
						"postalCode": "28078",
						"addressCountry": "US"
					},
					"geo": {
						"@type": "GeoCoordinates",
						"latitude": 35.4107,
						"longitude": -80.8428
					},
					"priceRange": "$$$$",
					"image": "https://cdn.sanity.io/images/2bom5gqg/production/21282e732035fa47572f5ca27d12ae838ef7fe43-600x400.jpg"
				},
				"areaServed": [
					{ "@type": "State", "name": "North Carolina" },
					{ "@type": "State", "name": "South Carolina" },
					{ "@type": "Country", "name": "United States" }
				],
				"serviceType": "Christian Marriage Counseling Intensive",
				"url": "https://thekohlergroup.net/intensives/marriage/"
			},
			{
				"@type": "Person",
				"name": "Barbara Kohler",
				"jobTitle": "Licensed Clinical Mental Health Counselor",
				"honorificSuffix": "MS, LCMHC",
				"url": "https://thekohlergroup.net/our-therapists/barbara-j-kohler/",
				"worksFor": {
					"@type": "LocalBusiness",
					"name": "The Kohler Group, PLLC"
				},
				"knowsAbout": ["Christian counseling", "marriage intensives", "EMDR", "Re-decision Therapy", "Trauma Resolution Energy Therapy", "faith-based psychotherapy", "trauma therapy", "Advanced Integrative Therapy", "inner child work", "Transactional Analysis", "double chair work", "spirit-filled therapy", "couples therapy"]
			},
			{
				"@type": "VideoObject",
				"name": "Christian Marriage Intensive — The Kohler Group",
				"description": "Learn about the Christian marriage intensive experience with Barbara Kohler at The Kohler Group in Huntersville, NC.",
				"contentUrl": "https://www.youtube.com/watch?v=l_mb3yx43I0",
				"thumbnailUrl": "https://cdn.sanity.io/images/2bom5gqg/production/21282e732035fa47572f5ca27d12ae838ef7fe43-600x400.jpg",
				"uploadDate": "2025-01-01"
			}
		]
	})} />

	<!-- Hero -->
	<section
		class="relative flex h-[250px] items-center justify-center bg-cover bg-top bg-no-repeat"
		style="background-image: url('https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg')"
	>
		<div class="absolute inset-0 bg-brand/80"></div>
		<div class="container relative z-10 text-center">
			<h1 class="text-4xl font-bold uppercase tracking-caps text-white sm:text-5xl">
				Christian Marriage Intensive
			</h1>
			<p class="mt-4 text-base font-medium text-white/80">
				Led by Barbara Kohler, MS, LCMHC · Huntersville, NC
			</p>
		</div>
	</section>

	<!-- Intro + Video -->
	<section class="py-20">
		<div class="container max-w-6xl">
			<div class="grid items-start gap-12 lg:grid-cols-2">
				<div>
					<p class="text-base leading-relaxed text-gray-700">
						Barbara Kohler's Christian marriage intensive is a concentrated, multi-day counseling experience where both partners do deep therapy work on their relationship. Together we discover the root causes, heal the wounds, and help couples rebuild their conversation and care for one another. While you are here, there will be light homework, mapping out your repetitive loops, and completing worksheets in session to activate your thinking in a positive way.
					</p>
					<p class="mt-4 text-base leading-relaxed text-gray-700">
						Barbara Kohler, MS, LCMHC, is a licensed Christian counselor with decades of experience leading faith-based marriage intensives from her practice in Huntersville, North Carolina. Her approach is both clinical and spiritual — combining evidence-based psychotherapy with Biblical principles. Often, when Jesus ministered, He gave people teaching and instruction as well as a healing or miraculous experience. These Christian marriage intensives are inspired by this approach.
					</p>
				</div>
				<div class="overflow-hidden rounded-xl shadow-lg">
					<p class="mb-2 text-xs font-semibold uppercase tracking-caps text-brand/60">Watch</p>
					<h3 class="mb-3 text-base font-bold text-brand">Christian Marriage Intensive: Healing, Restoration &amp; Real Results | The Kohler Group</h3>
					<div class="aspect-video w-full">
						<iframe
							class="h-full w-full rounded-lg"
							src="https://www.youtube.com/embed/l_mb3yx43I0"
							title="Christian Marriage Intensive: Healing, Restoration & Real Results | The Kohler Group"
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen
						></iframe>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Client Satisfaction -->
	<section class="bg-brand py-16">
		<div class="container max-w-4xl text-center">
			<p class="text-xs font-bold uppercase tracking-caps text-white/70">Client Results</p>
			<h2 class="mt-3 text-3xl font-bold uppercase tracking-caps text-white">
				100% Client Satisfaction
			</h2>
			<p class="mt-2 text-sm font-semibold uppercase tracking-caps text-white/80">
				Based on Post-Intensive Surveys
			</p>
			<p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-white/80">
				Following completion of their intensive, clients were invited to complete a feedback survey. Every respondent reported that the intensive met their goals and expectations, and 100% said they would recommend our individual or marriage intensives to others. Clients consistently reported improved communication with their partner, greater understanding of their faith and how it relates to their relationship, increased emotional well-being, and better conflict resolution skills.
			</p>
			<MailtoLink
				email={settings?.barbaraEmail}
				class="mt-10 inline-block rounded-full bg-white px-10 py-3 text-xs font-bold uppercase tracking-ui text-brand transition hover:bg-white/90"
			>
				Get Started
			</MailtoLink>
		</div>
	</section>

	<!-- Three Stages of Healing -->
	<section class="py-20">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">Where Are You?</p>
			<h2 class="section-title mb-6">Healing Takes Place in Stages</h2>
			<p class="mb-10 text-base leading-relaxed text-gray-700">
				I find people come into therapy at one of three stages, and each of these stages has varying degrees of intensity.
			</p>
			<div class="space-y-6">
				{healingStages.map((stage: any) => (
					<div class="flex gap-6">
						<div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-brand text-sm font-bold text-white">
							{stage.number}
						</div>
						<div>
							<h3 class="font-bold uppercase tracking-caps text-brand">{stage.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-gray-700">{stage.body}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Awareness Stages -->
	<section class="bg-gray-50 py-20">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">The Process</p>
			<h2 class="section-title mb-6">Awareness Comes in Stages</h2>
			<div class="space-y-6">
				{awarenessStages.map((stage: any) => (
					<div class="flex gap-6">
						<div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-brand text-sm font-bold text-white">
							{stage.number}
						</div>
						<div>
							<h3 class="font-bold uppercase tracking-caps text-brand">{stage.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-gray-700">{stage.body}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Barbara Kohler Image -->
	<section class="bg-white py-10">
		<div class="container max-w-4xl">
			<img
				src="https://cdn.sanity.io/images/2bom5gqg/production/21282e732035fa47572f5ca27d12ae838ef7fe43-600x400.jpg"
				alt="Barbara Kohler, Christian marriage intensive counselor in Huntersville, NC"
				class="w-full rounded-lg object-cover shadow-md"
				width="600"
				height="400"
				loading="lazy"
			/>
			<p class="mt-3 text-center text-sm text-gray-500">Barbara Kohler, MS, LCMHC — leading Christian marriage intensives in Huntersville, NC</p>
		</div>
	</section>

	<!-- While You Are Here -->
	<section class="py-20">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">Preparation</p>
			<h2 class="section-title mb-8">While You Are Here</h2>
			<ul class="space-y-4">
				{preparationItems.map((item: any) => (
					<li class="flex items-start gap-3">
						<span class="mt-1.5 h-2 w-2 flex-shrink-0 rounded-full bg-brand" />
						<p class="text-sm leading-relaxed text-gray-700">{item.body}</p>
					</li>
				))}
			</ul>
		</div>
	</section>

	<!-- Day by Day -->
	<section class="bg-gray-50 py-20">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">The Schedule</p>
			<h2 class="section-title mb-10">The Five-Day Christian Marriage Intensive</h2>
			<div class="space-y-12">
				{dayGroups.map((day) => (
					<div>
						<h3 class="mb-6 text-lg font-bold uppercase tracking-caps text-brand border-b border-brand/20 pb-2">{day.label}</h3>
						<div class="space-y-6">
							{day.sessions.map((session) => (
								<div>
									{session.sessionLabel && (
										<p class="mb-3 text-xs font-bold uppercase tracking-caps text-brand/70">{session.sessionLabel}</p>
									)}
									{session.prose ? (
										<div>
											{session.prose.split('\n\n').map((para: string) => (
												<p class="mt-3 text-sm leading-relaxed text-gray-700">{para}</p>
											))}
										</div>
									) : (
										<ol class="space-y-3 list-decimal pl-5" start={session.listStartNumber || 1}>
											{(session.items || []).map((item: string) => (
												<li class="text-sm leading-relaxed text-gray-700">{item}</li>
											))}
										</ol>
									)}
									{session.note && (
										<p class="mt-4 text-sm leading-relaxed text-gray-700 italic">{session.note}</p>
									)}
								</div>
							))}
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- When You Get Home -->
	<section class="py-20">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">After the Intensive</p>
			<h2 class="section-title mb-8">When You Get Home</h2>
			<ol class="space-y-4 list-decimal pl-5">
				{[
					'Please let me know when you have arrived home or to your destination safely.',
					'Check-in through the portal within one week to let me know how you are doing as you re-enter the atmosphere.',
					'Live and love well.',
				].map((item) => (
					<li class="text-sm leading-relaxed text-gray-700">{item}</li>
				))}
			</ol>
		</div>
	</section>

	<!-- For Trauma Survivors -->
	<section class="bg-brand/5 py-16">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">Important Note</p>
			<h2 class="section-title mb-6">For Trauma Survivors</h2>
			<p class="text-sm leading-relaxed text-gray-700">
				If you are working through relational or any other type of trauma, and coming from out of state, you are responsible to have a local therapist for mental health emergencies, weekly sessions if you need, and other types of situations that need to be handled on sight with a trained therapist.
			</p>
		</div>
	</section>

	<!-- Closing Note -->
	<section class="py-20">
		<div class="container max-w-4xl">
			<p class="text-base leading-relaxed text-gray-700">
				Come with an open mind. Your spouse is not your enemy. They are your opportunity. If you feel like God has led you here, trust Him. If there is a particular technique you are not comfortable with, I will not compel you to engage that technique. Just know it can limit your level of transformation. If you are okay with that, I am okay with that. If you would like to seek the Lord regarding your resistance to a technique, I welcome that. Everywhere Jesus went, He gave people an experience of Himself. My prayer for your marriage is that you each experience God in a deep way and your life together will be better for having done this Intensive.
			</p>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-white py-20">
		<div class="container text-center">
			<h2 class="text-3xl font-bold uppercase tracking-caps text-brand">
				Ready to Begin?
			</h2>
			<p class="mx-auto mt-6 max-w-xl text-base text-gray-600">
				Contact us to learn more about scheduling a Marriage Intensive. We'll help you find the right fit for your needs.
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<MailtoLink
					email={settings?.barbaraEmail}
					class="btn-primary inline-block"
				>
					Get Started
				</MailtoLink>
				<a
					href={`tel:${settings?.phone?.replace(/-/g, '')}`}
					class="inline-block border-2 border-brand px-8 py-3 text-xs font-bold uppercase tracking-ui text-brand transition hover:bg-brand hover:text-white"
				>
					Call {settings?.phone}
				</a>
			</div>
		</div>
	</section>
</Layout>
