---
import { getImage } from 'astro:assets';
import TraumaIntensiveQuiz from '@components/TraumaIntensiveQuiz.astro';
import Layout from '@layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{
  phone, email, barbaraEmail, officeEmail,
  hytVideoUrl, hytHeroBackground, hytBarbaraPhoto, hytPrice, hytEnvironmentImages,
  somBarbaraPhoto
}`);

const traumaTestimonials = await sanityClient.fetch(`
  *[_type == "testimonial" && service == "Trauma Intensive"] | order(order asc) {
    _id, clientName, quote
  }
`);

// Fallback testimonials from Barbara's prototype — used until Sanity has any
// posts tagged "Trauma Intensive". Kept generic + identity-free.
const fallbackTestimonials = [
	{
		_id: 'fb-1',
		clientName: 'Intensive Client',
		quote:
			"I wasn't sure what to expect in the beginning. But it was so much better than what I could have thought. Thank you so much!",
	},
	{
		_id: 'fb-2',
		clientName: 'Intensive Client',
		quote:
			'The flow of the day was well paced, including breaks and ending early enough to have time after to process. I liked the variation in modalities used. It kept things interesting and gave me a way to connect to differently.',
	},
	{
		_id: 'fb-3',
		clientName: 'Former Client',
		quote:
			"I arrived broken and hopeless with feelings of failure and a loss of purpose. I was no longer able to push back the images of abuse and years of secrecy and confusion. Barbara asked me simple questions and affirmed my pain and helped me feel seen and heard. She introduced me to the power of the Holy Spirit and the unconditional love of the Lord. Through clinical techniques as a master psychotherapist, and through Biblical knowledge and wisdom, Barbara continues to guide me in Redecision Therapy and experience the freedom of God's grace and protection. After decades of talk therapy with a variety of therapists, I had given up on counseling. I am grateful to my husband for encouraging me to call Barbara's office and I am forever grateful for the woman who answered the phone, listened to me cry, and immediately scheduled me to see Barbara. My phone rang seconds later and it was Barbara, herself, and my healing began. Today, I walk, with confidence, through my past and my present. I am able to embrace my God given gifts, forgive those who have caused me pain and isolation, and I actively pursue opportunities to share my testimony with others so they feel the common bond of trauma, but hear the truth in God's restoration, and the hope of a fulfilling life of promises found in the healing within working with Barbara and the blessings of a Godly woman and therapist.",
	},
	{
		_id: 'fb-4',
		clientName: 'Intensive Client',
		quote:
			'The first time I came to see Barbara I was in a desperate place. I had tried multiple other therapists and types of counseling. Nothing was helping beyond essentially medicating the pain and trauma I was working through. By the time I reached her, it would have been similar to someone coming into the emergency room on a crash cart. Barely alive. I needed assistance to feed and dress myself and was not safe to drive a car. My first Intensive with Barbara put me on life support and gave me the first glimpse of hope in many many months. I continued forward with her guidance and multiple Intensives to follow. I can honestly say that I am alive today as a result of her therapeutic techniques and work. I and my family will be forever grateful.',
	},
];
const testimonials =
	traumaTestimonials && traumaTestimonials.length > 0 ? traumaTestimonials : fallbackTestimonials;

const price = settings?.hytPrice || '$9,400';

function getYouTubeId(url: string | null | undefined): string | null {
	if (!url) return null;
	const m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]{11})/);
	return m ? m[1] : null;
}
const videoId: string | null = getYouTubeId(settings?.hytVideoUrl);
const videoTitle = 'Hear From Barbara — Trauma Intensive';

let ytThumb: Awaited<ReturnType<typeof getImage>> | null = null;
if (videoId) {
	try {
		ytThumb = await getImage({
			src: `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`,
			width: 1280,
			height: 720,
			format: 'webp',
			quality: 60,
			widths: [540, 720, 1080, 1280],
		});
	} catch (err) {
		console.warn('[heal-your-trauma] YouTube thumbnail prefetch failed:', err);
	}
}

const barbaraEmail = settings?.barbaraEmail || 'barbara@thekohlergroup.net';
const officeEmail = settings?.officeEmail || 'Ashley.Bostic@thekohlergroup.net';
const phone = settings?.phone || '704-948-1268';
const phoneDigits = phone.replace(/[^0-9]/g, '');

// Barbara bio photo — Sanity override (hyt-specific) > the prototype's
// own headshot uploaded to TKG's Sanity asset library.
const barbaraPortraitSource = settings?.hytBarbaraPhoto;
const barbaraPhotoUrl = barbaraPortraitSource
	? urlFor(barbaraPortraitSource)
			.width(560)
			.height(700)
			.fit('crop')
			.format('webp')
			.quality(85)
			.url()
	: 'https://cdn.sanity.io/images/2bom5gqg/production/26668c3345068c6b44adc469806a72a911d51919-512x640.jpg?w=560&h=700&fit=crop&auto=format';

// Hero background — Sanity override > the prototype's own pond/bridge
// photo of Daetwyler Plaza. A navy 88% overlay sits on top via CSS.
const heroBgUrl = settings?.hytHeroBackground
	? urlFor(settings.hytHeroBackground).width(1920).format('webp').quality(80).url()
	: 'https://cdn.sanity.io/images/2bom5gqg/production/6760f67fe866be9af8c60dea85be28951f8f3876-1400x933.jpg?w=1400&fm=webp&q=80';

// Environment grid — Sanity override > the four prototype Daetwyler photos
// uploaded to TKG's Sanity asset library (lake, walking path, geese, bridge).
const FALLBACK_ENV = [
	{
		url: 'https://cdn.sanity.io/images/2bom5gqg/production/2ac09ed86e7035906b03a9758dce48117fbbfb7e-1400x933.jpg?w=720&h=480&fit=crop&fm=webp&q=80',
		alt: 'Lake at Daetwyler Plaza',
	},
	{
		url: 'https://cdn.sanity.io/images/2bom5gqg/production/892ea2206b9b5617808d0b87ec78b0bb68e77d0b-900x600.jpg?w=720&h=480&fit=crop&fm=webp&q=80',
		alt: 'Walking path at Daetwyler Plaza',
	},
	{
		url: 'https://cdn.sanity.io/images/2bom5gqg/production/6f5a86ed5ee0325184863f6c3bea9c8109dda415-900x1349.jpg?w=720&h=480&fit=crop&crop=top&fm=webp&q=80',
		alt: 'Geese at the lake',
	},
	{
		url: 'https://cdn.sanity.io/images/2bom5gqg/production/6760f67fe866be9af8c60dea85be28951f8f3876-1400x933.jpg?w=720&h=480&fit=crop&fm=webp&q=80',
		alt: 'Pond with bridge at Daetwyler Plaza',
	},
];
const envImages =
	Array.isArray(settings?.hytEnvironmentImages) && settings.hytEnvironmentImages.length >= 4
		? settings.hytEnvironmentImages.slice(0, 4).map((img: any) => ({
				url: urlFor(img).width(720).height(480).fit('crop').format('webp').quality(80).url(),
				alt: img.alt || 'Daetwyler Plaza environment',
			}))
		: FALLBACK_ENV;

const canonicalURL = 'https://thekohlergroup.net/heal-your-trauma';
const ogImage =
	'https://cdn.sanity.io/images/2bom5gqg/production/4acc15cc5d36b1bddfad65074b71a61ac1653349-1280x720.jpg?fm=jpg&q=95&sharpen=15';

const logoUrl =
	'https://cdn.sanity.io/images/2bom5gqg/production/c60dd6674bab6d1f50562e6ff3f61365e0639f1a-1416x921.png?w=400';
---

<Layout
	title="Heal Your Trauma | Individual Intensive — Barbara Kohler, LCMHC"
	description="Trauma is stealing your business, your relationships, your finances, and your hope. The Individual Trauma Intensive with Barbara Kohler, LCMHC offers concentrated, root-cause healing for high achievers, business owners, and ministers — three concentrated days in Huntersville, NC."
	canonicalURL={canonicalURL}
	ogImage={ogImage}
	landing={true}
	bodyClass="hyt-page"
>
	<Fragment slot="head">
		{ytThumb && (
			<link
				rel="preload"
				as="image"
				href={ytThumb.src}
				imagesrcset={ytThumb.srcSet?.attribute}
				imagesizes="(max-width: 1024px) 90vw, 540px"
				fetchpriority="high"
			/>
		)}
		<link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/lato/lato-400.woff2" crossorigin />
		<link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/lato/lato-700.woff2" crossorigin />
		<style is:inline>
			@font-face{font-family:'Lato';font-style:normal;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/lato/lato-400.woff2') format('woff2')}
			@font-face{font-family:'Lato';font-style:normal;font-weight:700;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/lato/lato-700.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:600;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-600.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:700;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-700.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:italic;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-400-italic.woff2') format('woff2')}
			@font-face{font-family:'Cormorant Garamond';font-style:italic;font-weight:500;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/cormorant-garamond/cormorant-garamond-500-italic.woff2') format('woff2')}

			/* ======================================================================
			   Heal Your Trauma — ported verbatim from Barbara's prototype CSS,
			   scoped under body.hyt-page so nothing leaks into the rest of TKG.
			   Sapphire/gold/cream palette + Cormorant Garamond.
			   ====================================================================== */
			@layer base {
				/* Override Layout.astro critical CSS h1-h6 { line-height: 1.2 } so
				   headings without an explicit line-height inherit the body's
				   1.75 (matches Barbara's prototype). */
				body.hyt-page h1,
				body.hyt-page h2,
				body.hyt-page h3,
				body.hyt-page h4,
				body.hyt-page h5,
				body.hyt-page h6 {
					line-height: inherit;
				}
				body.hyt-page {
					--hyt-sapphire: #1b3a6b;
					--hyt-sapphire-dark: #0f2347;
					--hyt-sapphire-mid: #254d8f;
					--hyt-gold: #b8872a;
					--hyt-gold-light: #d4a843;
					--hyt-gold-pale: #f5e6c8;
					--hyt-cream: #faf7f2;
					--hyt-white: #ffffff;
					--hyt-text-dark: #0d1117;
					--hyt-text-body: #1a202c;
					--hyt-text-mid: #2d3748;
					--hyt-text-muted: #4a5568;
					--hyt-light-gray: #e8e4de;
					--hyt-shadow: 0 4px 24px rgba(27, 58, 107, 0.13);
					font-family: 'Lato', system-ui, sans-serif;
					background: var(--hyt-white);
					color: var(--hyt-text-body);
					font-size: 17px;
					line-height: 1.75;
				}
				body.hyt-page * { box-sizing: border-box; }
				body.hyt-page html { scroll-behavior: smooth; }

				body.hyt-page .hyt-container {
					max-width: 960px;
					margin: 0 auto;
					padding: 0 28px;
				}

				body.hyt-page .hyt-section-label {
					font-family: 'Lato', system-ui, sans-serif;
					font-size: 11px;
					font-weight: 700;
					letter-spacing: 3px;
					text-transform: uppercase;
					color: var(--hyt-gold);
					margin-bottom: 12px;
					display: block;
				}
				body.hyt-page .hyt-section-title {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: clamp(32px, 5vw, 50px);
					font-weight: 600;
					color: var(--hyt-sapphire-dark);
					line-height: 1.15;
					margin-bottom: 20px;
				}
				body.hyt-page .hyt-section-title em { font-style: italic; color: var(--hyt-gold); }
				body.hyt-page .hyt-section-body {
					font-size: 17px;
					color: var(--hyt-text-body);
					max-width: 680px;
					line-height: 1.8;
				}
				body.hyt-page .hyt-section-header { text-align: center; margin-bottom: 56px; }
				body.hyt-page .hyt-section-header .hyt-section-body { margin: 0 auto; }
				body.hyt-page .hyt-gold-rule {
					width: 60px;
					height: 3px;
					background: var(--hyt-gold);
					margin: 20px auto 0;
					border: none;
				}

				body.hyt-page .hyt-btn-primary-link {
					display: inline-block;
					background: var(--hyt-gold);
					color: var(--hyt-white);
					font-family: 'Lato', system-ui, sans-serif;
					font-size: 13px;
					font-weight: 700;
					letter-spacing: 2px;
					text-transform: uppercase;
					padding: 16px 36px;
					border-radius: 2px;
					text-decoration: none;
					transition: background 0.2s, transform 0.2s;
					cursor: pointer;
					border: none;
				}
				body.hyt-page .hyt-btn-primary-link:hover {
					background: var(--hyt-gold-light);
					transform: translateY(-1px);
				}

				/* HEADER + TOPBAR */
				body.hyt-page .hyt-header {
					background: var(--hyt-white);
					padding: 14px 28px;
					display: flex;
					align-items: center;
					justify-content: space-between;
					border-bottom: 2px solid #e8eef8;
					position: sticky;
					top: 0;
					z-index: 100;
					box-shadow: 0 2px 12px rgba(27, 58, 107, 0.08);
				}
				body.hyt-page .hyt-header > img { height: 40px; width: auto; }
				body.hyt-page .hyt-nav {
					display: flex;
					gap: 20px;
					align-items: center;
				}
				body.hyt-page .hyt-nav a:not(.hyt-btn-primary-link) {
					font-size: 13px;
					font-weight: 700;
					letter-spacing: 1px;
					color: var(--hyt-sapphire-dark);
					text-decoration: none;
					text-transform: uppercase;
				}
				body.hyt-page .hyt-nav .hyt-btn-primary-link {
					padding: 10px 20px;
					font-size: 12px;
				}
				body.hyt-page .hyt-nav-toggle { display: none; }
				@media (max-width: 768px) {
					body.hyt-page .hyt-nav-toggle {
						display: inline-flex;
						flex-direction: column;
						justify-content: space-between;
						width: 28px;
						height: 22px;
						background: transparent;
						border: 0;
						padding: 0;
						cursor: pointer;
					}
					body.hyt-page .hyt-nav-toggle span {
						display: block;
						width: 100%;
						height: 3px;
						background: var(--hyt-sapphire-dark);
						border-radius: 2px;
						transition: transform 0.25s ease, opacity 0.2s ease;
						transform-origin: center;
					}
					body.hyt-page .hyt-nav-toggle[aria-expanded='true'] span:nth-child(1) {
						transform: translateY(9px) rotate(45deg);
					}
					body.hyt-page .hyt-nav-toggle[aria-expanded='true'] span:nth-child(2) {
						opacity: 0;
					}
					body.hyt-page .hyt-nav-toggle[aria-expanded='true'] span:nth-child(3) {
						transform: translateY(-10px) rotate(-45deg);
					}
					body.hyt-page .hyt-nav {
						position: absolute;
						top: 100%;
						left: 0;
						right: 0;
						background: var(--hyt-white);
						flex-direction: column;
						align-items: stretch;
						padding: 12px 28px 24px;
						gap: 4px;
						border-bottom: 2px solid #e8eef8;
						box-shadow: 0 6px 16px rgba(27, 58, 107, 0.1);
						transform: translateY(-12px);
						opacity: 0;
						pointer-events: none;
						transition: transform 0.25s ease, opacity 0.2s ease;
					}
					body.hyt-page .hyt-nav.is-open {
						transform: translateY(0);
						opacity: 1;
						pointer-events: auto;
					}
					body.hyt-page .hyt-nav a:not(.hyt-btn-primary-link) {
						padding: 14px 0;
						border-bottom: 1px solid #e8eef8;
						font-size: 14px;
					}
					body.hyt-page .hyt-nav .hyt-btn-primary-link {
						margin-top: 12px;
						text-align: center;
						padding: 14px 20px;
					}
				}
				body.hyt-page .hyt-topbar {
					background: var(--hyt-sapphire-dark);
					padding: 10px 28px;
					text-align: center;
					font-size: 13px;
					color: #c5d2e8;
					letter-spacing: 0.5px;
					display: flex;
					align-items: center;
					justify-content: center;
					gap: 24px;
					flex-wrap: wrap;
				}
				body.hyt-page .hyt-topbar img { height: 32px; width: auto; }
				body.hyt-page .hyt-topbar a {
					color: var(--hyt-gold-light);
					text-decoration: none;
					font-weight: 700;
				}
				@media (max-width: 768px) {
					body.hyt-page .hyt-topbar {
						gap: 8px;
						padding: 8px 20px;
						font-size: 12px;
					}
					body.hyt-page .hyt-topbar img,
					body.hyt-page .hyt-topbar .hyt-topbar-serving { display: none; }
				}

				/* HERO */
				body.hyt-page .hyt-hero {
					background: var(--hyt-sapphire-dark);
					color: var(--hyt-white);
					padding: 72px 28px 80px;
					position: relative;
					overflow: hidden;
				}
				body.hyt-page .hyt-hero.has-bg-image {
					background-size: cover;
					background-position: center;
				}
				body.hyt-page .hyt-hero::before {
					content: '';
					position: absolute;
					inset: 0;
					background: radial-gradient(ellipse at 60% 40%, rgba(184, 135, 42, 0.12) 0%, transparent 65%);
					pointer-events: none;
				}
				body.hyt-page .hyt-hero-inner {
					display: grid;
					grid-template-columns: 1fr 1fr;
					gap: 52px;
					align-items: center;
					max-width: 1060px;
					margin: 0 auto;
					position: relative;
					z-index: 2;
				}
				body.hyt-page .hyt-hero-text { text-align: left; }
				body.hyt-page .hyt-hero-eyebrow {
					font-size: 15px;
					font-weight: 700;
					letter-spacing: 4px;
					text-transform: uppercase;
					color: var(--hyt-gold-light);
					margin-bottom: 20px;
					display: block;
				}
				body.hyt-page .hyt-hero h1 {
					font-family: 'Cormorant Garamond', Georgia, serif;
					font-size: clamp(36px, 5vw, 62px);
					font-weight: 700;
					line-height: 1.08;
					margin-bottom: 24px;
					color: var(--hyt-white);
				}
				body.hyt-page .hyt-hero h1 em { font-style: italic; color: var(--hyt-gold-light); }
				body.hyt-page .hyt-hero-divider {
					width: 50px;
					height: 2px;
					background: var(--hyt-gold);
					margin: 24px 0;
				}
				body.hyt-page .hyt-hero-sub {
					font-size: 17px;
					color: #d0ddf5;
					margin: 0 0 32px;
					line-height: 1.75;
					font-weight: 300;
				}
				body.hyt-page .hyt-hero-creds {
					font-size: 13px;
					color: #9ab0d4;
					letter-spacing: 0.5px;
					margin-top: 24px;
				}
				body.hyt-page .hyt-hero-video-col { position: relative; }
				body.hyt-page .hyt-hero-video-label {
					font-size: 11px;
					font-weight: 700;
					letter-spacing: 2px;
					text-transform: uppercase;
					color: var(--hyt-gold-light);
					margin-bottom: 12px;
					display: block;
					text-align: center;
				}
				body.hyt-page .hyt-hero-video-wrap {
					background: rgba(255, 255, 255, 0.06);
					border: 2px solid rgba(212, 168, 67, 0.4);
					border-radius: 6px;
					aspect-ratio: 16 / 9;
					position: relative;
					overflow: hidden;
					box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
				}
				body.hyt-page button.hyt-hero-video-wrap {
					padding: 0;
					cursor: pointer;
					font: inherit;
					color: inherit;
					display: block;
					width: 100%;
				}
				body.hyt-page .hyt-hero-video-wrap > img {
					position: absolute;
					inset: 0;
					width: 100%;
					height: 100%;
					object-fit: cover;
					display: block;
				}
				body.hyt-page .hyt-hero-video-play {
					position: absolute;
					top: 50%;
					left: 50%;
					transform: translate(-50%, -50%);
					width: 68px;
					height: 48px;
					background: rgba(0, 0, 0, 0.72);
					border-radius: 12px;
					transition: background 0.2s ease;
					pointer-events: none;
				}
				body.hyt-page .hyt-hero-video-play::before {
					content: '';
					position: absolute;
					top: 50%;
					left: 50%;
					transform: translate(-50%, -50%);
					margin-left: 3px;
					border-style: solid;
					border-width: 9px 0 9px 15px;
					border-color: transparent transparent transparent #fff;
				}
				body.hyt-page button.hyt-hero-video-wrap:hover .hyt-hero-video-play,
				body.hyt-page button.hyt-hero-video-wrap:focus-visible .hyt-hero-video-play {
					background: #c00;
				}
				body.hyt-page .hyt-hero-video-placeholder {
					display: flex;
					flex-direction: column;
					align-items: center;
					justify-content: center;
					color: #9ab0d4;
					font-size: 14px;
					height: 100%;
				}
				body.hyt-page .hyt-hero-video-placeholder .hyt-play-icon {
					width: 56px;
					height: 56px;
					border: 3px solid var(--hyt-gold);
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					margin-bottom: 14px;
					color: var(--hyt-gold);
					font-size: 22px;
				}

				/* Video modal */
				body.hyt-page .hyt-video-modal {
