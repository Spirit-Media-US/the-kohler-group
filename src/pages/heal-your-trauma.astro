	<!-- =============== HEADER + TOPBAR =============== -->
	<header class="hyt-header">
		<img src={logoUrl} alt="The Kohler Group, PLLC" />
		<button
			type="button"
			class="hyt-nav-toggle"
			aria-expanded="false"
			aria-controls="hyt-nav-menu"
			aria-label="Toggle navigation menu"
			data-hyt-nav-toggle
		>
			<span></span>
			<span></span>
			<span></span>
		</button>
		<nav id="hyt-nav-menu" class="hyt-nav" data-hyt-nav>
			<a href="#pillars">How It Works</a>
			<a href="#contact">Contact</a>
			<a href="#screener" class="hyt-btn-primary-link">Apply Now</a>
		</nav>
	</header>
	<div class="hyt-topbar">
		<img src={logoUrl} alt="" />
		<span>
			Questions? Call <a href={`tel:${phoneDigits}`}>{phone}</a> &nbsp;|&nbsp;
			<a href={`mailto:${officeEmail}`}>{officeEmail}</a>
			<span class="hyt-topbar-serving">
				&nbsp;|&nbsp; Serving clients nationally from Huntersville, NC
			</span>
		</span>
	</div>

	<!-- =============== HERO =============== -->
	<section
		class:list={["hyt-hero", heroBgUrl && "has-bg-image"]}
		style={heroBgUrl
			? `background-image: linear-gradient(rgba(15,35,71,0.88), rgba(15,35,71,0.88)), url(${heroBgUrl});`
			: undefined}
	>
		<div class="hyt-hero-inner">
			<div class="hyt-hero-text">
				<span class="hyt-hero-eyebrow">
					Individual Trauma Intensive &nbsp;·&nbsp; The Kohler Group, PLLC
				</span>
				<h1>Trauma Is Stealing<br /><em>Everything You've Built.</em></h1>
				<div class="hyt-hero-divider"></div>
				<p class="hyt-hero-sub">
					Your business. Your marriage. Your finances. Your calling. Your hope. Time does not heal all
					wounds. But you can, indeed, heal. Gain incredible momentum in your healing journey in
					three concentrated days working with a seasoned clinician who uses a multidimensional
					approach.
				</p>
				<p class="hyt-hero-creds">
					Barbara Kohler, MS, CRC, LCMHC, NCC &nbsp;·&nbsp; Ordained Minister &nbsp;·&nbsp; 30+ Years
					Experience
				</p>
			</div>
			<div class="hyt-hero-video-col">
				<span class="hyt-hero-video-label">Hear From Barbara</span>
				{ytThumb ? (
					<button
						type="button"
						class="hyt-hero-video-wrap"
						data-yt-id={videoId}
						aria-label={`Play video: ${videoTitle}`}
					>
						<img
							src={ytThumb.src}
							srcset={ytThumb.srcSet?.attribute}
							sizes="(max-width: 1024px) 90vw, 540px"
							width="1280"
							height="720"
							alt=""
							fetchpriority="high"
							decoding="async"
						/>
						<span class="hyt-hero-video-play" aria-hidden="true"></span>
					</button>
				) : (
					<div class="hyt-hero-video-wrap" aria-label="Video coming soon">
						<div class="hyt-hero-video-placeholder">
							<div class="hyt-play-icon">▶</div>
							<p>Video coming soon</p>
						</div>
					</div>
				)}
			</div>
		</div>
	</section>

	<!-- =============== SCRIPTURE STRIP 1 =============== -->
	<div class="hyt-scripture-strip">
		<blockquote>"He heals the brokenhearted and binds up their wounds."</blockquote>
		<cite>Psalm 147:3 &nbsp;·&nbsp; NASB</cite>
	</div>

	<!-- =============== TESTIMONIALS =============== -->
