	<!-- Video modal (popup overlay) — opened from any [data-yt-id] facade -->
	<div class="hyt-video-modal" data-video-modal hidden role="dialog" aria-modal="true" aria-label={videoTitle}>
		<div class="hyt-video-modal-backdrop" data-video-modal-close></div>
		<div class="hyt-video-modal-content" data-video-modal-content>
