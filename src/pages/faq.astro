---
import { sanityClient, urlFor } from "../lib/sanity.ts";
import Layout from "@layouts/Layout.astro";
import { toPlainText } from "@portabletext/toolkit";
import { PortableText } from "astro-portabletext";

const [faqs, settings] = await Promise.all([
  sanityClient.fetch(`*[_type=="faq"] | order(order asc) { _id, question, answer, category, order }`),
  sanityClient.fetch(`*[_type=="siteSettings"][0]{ phone, email, barbaraEmail, officeEmail, bookingUrl, facebook, instagram, heroImage, aboutHeroImage, defaultHeroImage, logo }`),
]);
---

<Layout
	title="FAQ | Christian Counseling Questions | The Kohler Group, PLLC"
	description="Frequently asked questions about Christian counseling, insurance, scheduling, and our Statement of Faith at The Kohler Group in North Carolina."
>
	<!-- Hero -->
	<section
		class="relative flex h-[250px] items-center justify-center bg-cover bg-top bg-no-repeat"
		style="background-image: url('https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg')"
	>
		<div class="absolute inset-0 bg-brand/80"></div>
		<div class="container relative z-10 text-center">
			<h1 class="text-4xl font-bold uppercase tracking-caps text-white sm:text-5xl">
				Frequently Asked Questions
			</h1>
		</div>
	</section>

	<!-- FAQ Accordion -->
	<section class="py-20">
		<div class="container max-w-4xl">
			<div class="divide-y divide-gray-200">
				{
					faqs.map(({ question, answer, _id }, i) => (
						<details class="group py-5">
							<summary class="flex cursor-pointer items-start justify-between gap-4">
								<span class="text-sm font-semibold uppercase tracking-caps text-brand">
									{question}
								</span>
								<span class="mt-0.5 flex-shrink-0 text-brand transition group-open:rotate-45">
									<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M12 4v16m8-8H4"
										/>
									</svg>
								</span>
							</summary>
							<div class="mt-4 prose prose-sm max-w-none text-gray-700 [&_p]:leading-relaxed [&_p]:mt-3 [&_p]:text-gray-700 [&_strong]:text-brand [&_h3]:font-bold [&_h3]:uppercase [&_h3]:tracking-caps [&_h3]:text-brand [&_h3]:mt-5 [&_h3]:text-sm [&_h4]:font-bold [&_h4]:text-brand [&_h4]:mt-4 [&_h4]:text-sm">
								{answer && <PortableText value={answer} />}
							</div>

							<!-- Share Icons -->
							<div class="mt-4 flex items-center gap-3">
								<span class="text-xs text-black">Share:</span>

								{/* Facebook */}
								<a
									href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://thekohlergroup.com/faq')}&quote=${encodeURIComponent(question)}`}
									target="_blank"
									rel="noopener noreferrer"
									title="Share on Facebook"
									class="text-black transition hover:text-[#1877F2]"
								>
									<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
										<path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.884v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
									</svg>
								</a>

								{/* X / Twitter */}
								<a
									href={`https://twitter.com/intent/tweet?url=${encodeURIComponent('https://thekohlergroup.com/faq')}&text=${encodeURIComponent(question)}`}
									target="_blank"
									rel="noopener noreferrer"
									title="Share on X"
									class="text-black transition hover:text-black"
								>
									<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
										<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
									</svg>
								</a>

								{/* LinkedIn */}
								<a
									href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent('https://thekohlergroup.com/faq')}`}
									target="_blank"
									rel="noopener noreferrer"
									title="Share on LinkedIn"
									class="text-black transition hover:text-[#0A66C2]"
								>
									<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
									</svg>
								</a>

								{/* Copy Link */}
								<button
									data-copy-faq={i}
									title="Copy link"
									class="text-black transition hover:text-brand"
								>
									<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
									</svg>
								</button>
							</div>
						</details>
					))
				}
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-white py-20">
		<div class="container text-center">
			<h2 class="text-3xl font-bold uppercase tracking-caps text-brand">
				Still Have Questions?
			</h2>
			<p class="mx-auto mt-6 max-w-xl text-base text-gray-600">
				Call or text us at {settings?.phone} and we'll be happy to help.
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a
					href={settings?.bookingUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="btn-primary"
				>
					Request an Appointment
				</a>
				<a
					href={`tel:${settings?.phone?.replace(/-/g, '')}`}
					class="inline-block border-2 border-brand px-8 py-3 text-xs font-bold uppercase tracking-ui text-brand transition hover:bg-brand hover:text-white"
				>
					Call {settings?.phone}
				</a>
			</div>
		</div>
	</section>

<script>
	document.querySelectorAll('[data-copy-faq]').forEach((btn) => {
		btn.addEventListener('click', () => {
			navigator.clipboard.writeText(window.location.href).then(() => {
				const original = btn.innerHTML;
				btn.innerHTML = `<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`;
				setTimeout(() => { btn.innerHTML = original; }, 2000);
			});
		});
	});
</script>
</Layout>
