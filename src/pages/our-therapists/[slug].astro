---
import Layout from '@layouts/Layout.astro';
import { PortableText } from 'astro-portabletext';
import { sanityClient } from '../../lib/sanity.ts';

export async function getStaticPaths() {
	const therapists = await sanityClient.fetch(`
		*[_type == "therapist" && active != false && defined(slug.current)] {
			"slug": slug.current
		}
	`);
	return therapists.map((t: any) => ({
		params: { slug: t.slug },
	}));
}

const { slug } = Astro.params;
const therapist = await sanityClient.fetch(
	`
	*[_type == "therapist" && (slug.current == $slug || _id == $slug)][0] {
		name,
		credentials,
		role,
		intro,
		bio,
		"headshotUrl": headshot.asset->url,
		specializations,
		modalities
	}
`,
	{ slug },
);
const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{ officeEmail, bookingUrl }`);
---

<Layout
	title={`${therapist.name}, ${therapist.credentials} | Christian Therapist Huntersville NC`}
	description={`${therapist.name}, ${therapist.credentials} — licensed Christian therapist at The Kohler Group in Huntersville, NC. Faith-based psychotherapy serving Charlotte & Lake Norman.`}
	heroPreload="https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg"
>
	<!-- Person JSON-LD -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Person",
		"name": therapist.name,
		"jobTitle": therapist.role || "Licensed Christian Therapist",
		"honorificSuffix": therapist.credentials,
		"description": therapist.intro,
		"url": `https://thekohlergroup.net/our-therapists/${slug}/`,
		"image": therapist.headshotUrl ? `${therapist.headshotUrl}?w=600&h=600&fit=crop` : undefined,
		"worksFor": {
			"@type": "ProfessionalService",
			"name": "The Kohler Group PLLC",
			"url": "https://thekohlergroup.net",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "13420 Reese Blvd W",
				"addressLocality": "Huntersville",
				"addressRegion": "NC",
				"postalCode": "28078"
			}
		},
		...([...(therapist.specializations || []), ...(therapist.modalities || [])].length > 0 && {
			"knowsAbout": [...(therapist.specializations || []), ...(therapist.modalities || [])]
		})
	})} />

	<!-- Hero -->
	<section
		class="relative flex h-[250px] items-center justify-center bg-cover bg-top bg-no-repeat"
		style="background-image: url('https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg')"
	>
		<div class="absolute inset-0 bg-brand/80"></div>
		<div class="container relative z-10 text-center">
			<h1 class="text-4xl font-bold uppercase tracking-caps text-white sm:text-5xl">
				{therapist.name}
			</h1>
		</div>
	</section>

	<!-- Two-column: Photo + Intro bio -->
	<section class="py-20">
		<div class="container max-w-5xl">
			<div class="flex flex-col gap-10 lg:flex-row lg:items-start">

				<!-- Left: Photo + credentials -->
				<div class="flex-shrink-0 text-center lg:w-64">
					{therapist.headshotUrl ? (
						<img
							src={`${therapist.headshotUrl}?w=520&h=520&fit=max&auto=format`}
							srcset={`${therapist.headshotUrl}?w=260&h=260&fit=max&auto=format 260w, ${therapist.headshotUrl}?w=520&h=520&fit=max&auto=format 520w`}
							sizes="(max-width: 1024px) 260px, 256px"
							alt={`${therapist.name} headshot`}
							class="mx-auto w-full max-w-[260px] rounded-lg object-cover object-center shadow-md lg:max-w-full"
							width="520"
							height="520"
							loading="lazy"
						/>
					) : (
						<div class="mx-auto flex aspect-[3/4] w-full max-w-[260px] items-center justify-center rounded-lg bg-brand/10 lg:max-w-full">
							<svg class="h-24 w-24 text-brand/30" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
								<path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
							</svg>
						</div>
					)}
					<p class="mt-4 text-sm font-semibold text-brand">{therapist.credentials}</p>
					{therapist.role && <p class="mt-1 text-xs italic text-black">{therapist.role}</p>}
				</div>

				<!-- Right: Intro paragraph + button -->
				<div class="flex-1">
					<p class="text-sm leading-relaxed text-black">{therapist.intro}</p>
					<a
						href={settings?.bookingUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="btn-primary mt-8 inline-block"
					>
						Request an Appointment
					</a>
				</div>
			</div>

			<!-- Full bio from Sanity Portable Text -->
			{therapist.bio && therapist.bio.length > 0 && (
				<div class="prose prose-sm max-w-none mt-6 border-t border-gray-100 pt-6 text-black [&_p]:text-black [&_li]:text-black [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1 [&_ul]:mt-2 [&_p]:leading-relaxed [&_p]:mt-5 [&_strong]:text-brand">
					<PortableText value={therapist.bio} />
				</div>
			)}

			<!-- Back link -->
			<div class="mt-10">
				<a href="/our-therapists" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-ui text-brand transition hover:text-brand/70">
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
					</svg>
					Back to Our Therapists
				</a>
			</div>
		</div>
	</section>
</Layout>
