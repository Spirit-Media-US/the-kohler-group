---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';

export async function getStaticPaths() {
	const therapists = await getCollection('therapists');
	return therapists.map((therapist) => ({
		params: { slug: therapist.slug },
		props: { therapist },
	}));
}

const { therapist } = Astro.props;
const { Content } = await therapist.render();
const { name, credentials, role, headshot, intro } = therapist.data;
---

<Layout
	title={`${name} | The Kohler Group, PLLC`}
	description={`Learn more about ${name}, ${credentials} — a licensed therapist at The Kohler Group, PLLC offering Christian-based counseling.`}
>
	<!-- Hero -->
	<section
		class="relative flex h-[250px] items-center justify-center bg-cover bg-top bg-no-repeat"
		style="background-image: url('/images/therapists-hero.jpg')"
	>
		<div class="absolute inset-0 bg-brand/80"></div>
		<div class="container relative z-10 text-center">
			<h1 class="text-4xl font-bold uppercase tracking-caps text-white sm:text-5xl">
				{name}
			</h1>
		</div>
	</section>

	<!-- Two-column: Photo + Intro bio -->
	<section class="py-20">
		<div class="container max-w-5xl">
			<div class="flex flex-col gap-10 lg:flex-row lg:items-start">

				<!-- Left: Photo + credentials -->
				<div class="flex-shrink-0 text-center lg:w-64">
					{headshot ? (
						<img
							src={headshot}
							alt={`${name} headshot`}
							class="mx-auto w-full max-w-[260px] rounded-lg object-cover object-top shadow-md lg:max-w-full"
						/>
					) : (
						<div class="mx-auto flex aspect-[3/4] w-full max-w-[260px] items-center justify-center rounded-lg bg-brand/10 lg:max-w-full">
							<svg class="h-24 w-24 text-brand/30" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
								<path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
							</svg>
						</div>
					)}

					<!-- Credentials below photo -->
					<p class="mt-4 text-sm font-semibold text-brand">{credentials}</p>
					{role && (
						<p class="mt-1 text-xs italic text-black">{role}</p>
					)}
				</div>

				<!-- Right: Intro paragraph + button -->
				<div class="flex-1">
					<p class="text-sm leading-relaxed text-black">
						{intro}
					</p>

					<a
						href="mailto:office@thekohlergroup.net"
						class="btn-primary mt-8 inline-block"
					>
						Request an Appointment
					</a>
				</div>

			</div>

			<!-- Full-width: remaining bio paragraphs -->
			{intro && (
				<div class="prose prose-sm max-w-none mt-6 border-t border-gray-100 pt-6 text-black [&_p]:text-black [&_li]:text-black [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1 [&_ul]:mt-2 [&_p]:leading-relaxed [&_p]:mt-5 [&_strong]:text-brand">
					<Content />
				</div>
			)}

			{!intro && (
				<div class="prose prose-sm max-w-none mt-6 text-black [&_p]:text-black [&_li]:text-black [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1 [&_strong]:text-brand [&_p]:leading-relaxed">
					<Content />
				</div>
			)}

			<!-- Back link -->
			<div class="mt-10">
				<a
					href="/our-therapists"
					class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-ui text-brand transition hover:text-brand/70"
				>
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
					</svg>
					Back to Our Therapists
				</a>
			</div>
		</div>
	</section>
</Layout>
