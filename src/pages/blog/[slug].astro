---
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
	const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
	return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;

const post = await sanityClient.fetch(`*[_type == "blogPost" && slug.current == $slug][0]`, {
	slug,
});

if (!post) {
	return Astro.redirect('/blog');
}

function renderPortableText(blocks: any[]): string {
	if (!Array.isArray(blocks)) return '';

	const renderChildren = (children: any[]): string =>
		children
			.map((child: any) => {
				if (!child) return '';
				let text = child.text || '';
				const marks = Array.isArray(child.marks) ? child.marks : [];
				if (marks.length > 0) {
					if (marks.includes('strong')) text = `<strong>${text}</strong>`;
					if (marks.includes('em')) text = `<em>${text}</em>`;
					const linkMark = marks.find((m: any) => m && typeof m === 'object' && m._type === 'link');
					if (linkMark?.href) {
						text = `<a href="${linkMark.href}" class="text-brand hover:underline" target="_blank" rel="noopener noreferrer">${text}</a>`;
					}
				}
				return text;
			})
			.join('');

	const output: string[] = [];
	let listBuffer: string[] = [];
	let listType: string | null = null;

	const flushList = () => {
		if (listBuffer.length === 0) return;
		const tag = listType === 'number' ? 'ol' : 'ul';
		const listClass = listType === 'number' ? 'list-decimal' : 'list-disc';
		output.push(
			`<${tag} class="${listClass} pl-6 mb-6 space-y-2 text-lg text-gray-800 leading-relaxed">${listBuffer.join('')}</${tag}>`,
		);
		listBuffer = [];
		listType = null;
	};

	for (const block of blocks) {
		if (!block || block._type !== 'block') {
			flushList();
			continue;
		}

		const children = Array.isArray(block.children) ? block.children : [];
		const rawText = children.map((c: any) => c?.text || '').join('');
		if (/^\{[\w]+\}\s*[—–-]\s*\{[\w]+\}$/.test(rawText.trim())) continue;

		const textContent = renderChildren(children);

		if (block.listItem) {
			if (listType && listType !== block.listItem) flushList();
			listType = block.listItem;
			listBuffer.push(`<li>${textContent}</li>`);
			continue;
		}

		flushList();

		const style = block.style || 'normal';
		if (style === 'h2')
			output.push(
				`<h2 class="text-2xl font-bold uppercase tracking-caps text-brand mt-12 mb-4">${textContent}</h2>`,
			);
		else if (style === 'h3')
			output.push(
				`<h3 class="text-xl font-bold uppercase tracking-caps text-brand mt-8 mb-3">${textContent}</h3>`,
			);
		else output.push(`<p class="text-lg text-gray-800 leading-relaxed mb-4">${textContent}</p>`);
	}

	flushList();
	return output.join('');
}

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

const publishDate = formatDate(post.publishDate);
const heroImage = post.heroImage
	? urlFor(post.heroImage).width(1200).format('webp').url()
	: 'https://cdn.sanity.io/images/2bom5gqg/production/69ff224b35aa2d4c0e57339b5449330d55bf8095-468x311.jpg';
const author = post.author || 'Add Author Name Here';
const tags = post.tags || [];

const bodyHtml = renderPortableText(post.body);
---

<Layout
	title={post.seoTitle || `${post.title} | The Kohler Group Blog`}
	description={post.seoDescription || post.excerpt || 'Read this article on The Kohler Group blog'}
	ogImage={heroImage}
>
	<Fragment slot="head">
		<meta property="og:type" content="article" />
		<meta property="article:author" content={author} />
		<meta property="article:published_time" content={post.publishDate} />
		{tags.length > 0 && <meta property="article:section" content={tags[0]} />}
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": post.title,
			"description": post.excerpt || post.title,
			"image": heroImage,
			"author": { "@type": "Person", "name": author },
			"publisher": { "@type": "Organization", "name": "The Kohler Group PLLC", "url": "https://thekohlergroup.net" },
			"url": `https://thekohlergroup.net/blog/${post.slug.current}`,
			"datePublished": post.publishDate
		})}></script>
	</Fragment>

		<!-- HERO IMAGE -->
		<div class="w-full bg-brand">
			<img src={heroImage} alt={post.heroImage?.alt || post.title} class="w-full h-72 lg:h-[520px] object-cover object-top" />
		</div>

		<!-- POST HEADER -->
		<section class="bg-white px-6 pt-10 pb-2 lg:px-8">
			<div class="mx-auto max-w-3xl">
				<a href="/blog" class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-ui text-brand hover:text-brand-dark transition-colors mb-5">&larr; Back to Blog</a>
				<h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold uppercase tracking-caps text-brand">{post.title}</h1>
				{post.excerpt && <p class="mt-3 text-lg text-gray-700 max-w-2xl">{post.excerpt}</p>}
				<div class="flex items-center gap-3 mt-4 pb-8 text-sm text-gray-600 border-b border-gray-200">
					<span>By <span class="font-semibold text-brand">{author}</span></span>
					<span>&middot;</span>
					<span>{publishDate}</span>
				</div>
			</div>
		</section>

		<!-- TAGS -->
		{tags.length > 0 && (
			<section class="bg-white px-6 pb-6 lg:px-8 border-b border-gray-200">
				<div class="mx-auto max-w-3xl">
					<div class="flex flex-wrap gap-2">
						{tags.map((tag: string) => (
							<a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-xs font-semibold uppercase tracking-ui text-brand bg-brand/10 hover:bg-brand hover:text-white rounded-full px-3 py-1 transition-colors">
								{tag}
							</a>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- POST CONTENT -->
		<section class="bg-white px-6 py-10 lg:px-8 lg:py-16">
			<div class="mx-auto max-w-3xl">
				<div set:html={bodyHtml} />
			</div>
		</section>

		<ShareBar title={post.title} url={`https://thekohlergroup.net/blog/${post.slug.current}`} />

		<RelatedPosts currentSlug={`/blog/${post.slug.current}`} currentTags={tags} />
</Layout>
