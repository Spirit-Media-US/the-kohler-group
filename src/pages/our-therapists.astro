---
import { sanityClient, urlFor } from '../lib/sanity.ts';
import Layout from '@layouts/Layout.astro';

const therapists = await sanityClient.fetch(`
  *[_type == "therapist" && active != false] | order(order asc) {
    _id,
    name,
    credentials,
    role,
    intro,
    "slug": slug.current,
    "headshotUrl": headshot.asset->url,
    order
  }
`);
const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{
  phone, email, barbaraEmail, officeEmail, bookingUrl,
  facebook, instagram,
  heroImage, aboutHeroImage, defaultHeroImage, logo
}`);

---

<Layout
	title="Our Christian Counselors | Barbara Kohler & Team in Huntersville, NC"
	description="Meet Barbara Kohler and her team of licensed Christian counselors in Huntersville, NC. Individual sessions, marriage intensives, and individual intensives — all through a Christian worldview integrating clinical treatment with Biblical truth."
>
	<!-- Hero Banner -->
	<section
		class="relative flex h-[250px] items-center justify-center bg-cover bg-top bg-no-repeat"
		style="background-image: url('https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg')"
	>
		<div class="absolute inset-0 bg-brand/80"></div>
		<div class="container relative z-10 text-center">
			<h1 class="text-4xl font-bold uppercase tracking-caps text-white sm:text-5xl">
				Our Therapists
			</h1>
		</div>
	</section>

	<!-- Therapist Grid -->
	<section class="bg-white py-20">
		<div class="container">
			<p class="mx-auto mb-10 max-w-xl text-center text-base text-gray-600">
				Therapy is approached through a Christian worldview integrating clinical treatments with
				Biblical truths.
			</p>
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{therapists.map((therapist: any) => (
					<article class="flex flex-col overflow-hidden rounded-lg">
						<!-- Headshot -->
						<div class="aspect-square overflow-hidden bg-brand/10">
							{therapist.headshotUrl ? (
								<img
									src={`${therapist.headshotUrl}?w=600&h=600&fit=crop&auto=format`}
									alt={`${therapist.name} headshot`}
									class="h-full w-full object-cover object-top"
									loading="lazy"
								/>
							) : (
								<div class="flex h-full w-full items-center justify-center bg-brand/10">
									<svg class="h-24 w-24 text-brand/30" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
										<path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
									</svg>
								</div>
							)}
						</div>
						<!-- Info -->
						<div class="flex flex-1 flex-col items-center bg-brand px-6 py-8 text-center">
							<h2 class="text-base font-bold uppercase tracking-caps text-white">{therapist.name}</h2>
							<p class="mt-1 text-xs font-medium uppercase tracking-ui text-white/60">
								{therapist.credentials}
							</p>
							<div class="mt-auto pt-6 w-full flex justify-center">
								<a
									href={`/our-therapists/${therapist.slug || therapist._id}`}
									class="rounded-full border border-white px-8 py-2 text-xs font-bold uppercase tracking-ui text-white transition hover:bg-white hover:text-brand"
								>
									Read Bio
								</a>
							</div>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-white py-20">
		<div class="container text-center">
			<h2 class="text-3xl font-bold uppercase tracking-caps text-brand">
				Schedule with One of Our Therapists
			</h2>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a
					href={settings?.bookingUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block rounded-full bg-brand px-10 py-3 text-xs font-bold uppercase tracking-ui text-white transition hover:bg-brand/90"
				>
					Request an Appointment
				</a>
				<a
					href={`tel:${settings?.phone?.replace(/-/g, '')}`}
					class="inline-block rounded-full border-2 border-brand px-8 py-3 text-xs font-bold uppercase tracking-ui text-brand transition hover:bg-brand hover:text-white"
				>
					Call {settings?.phone}
				</a>
			</div>
		</div>
	</section>
</Layout>
