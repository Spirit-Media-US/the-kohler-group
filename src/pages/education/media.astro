---
import Layout from '@layouts/Layout.astro';
---

<Layout
	title="Media | The Kohler Group, PLLC"
	description="Media resources, interviews, articles, and educational content from The Kohler Group, PLLC — Christian counseling insights for your mental health journey."
>
	<!-- Hero -->
	<section
		class="relative flex h-[250px] items-center justify-center bg-cover bg-top bg-no-repeat"
		style="background-image: url('/images/therapists-hero.jpg')"
	>
		<div class="absolute inset-0 bg-brand/80"></div>
		<div class="container relative z-10 text-center">
			<h1 class="text-4xl font-bold uppercase tracking-caps text-white sm:text-5xl">
				Media
			</h1>
		</div>
	</section>

	<!-- Intro -->
	<section class="py-20">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">Resources & Content</p>
			<h2 class="section-title mb-8">Education Through Media</h2>
			<p class="text-base leading-relaxed text-gray-700">
				The Kohler Group is committed to equipping individuals, couples, and families with
				practical, faith-grounded mental health resources. Through interviews, articles,
				videos, and educational content, our team shares insights on Christian counseling,
				trauma recovery, marriage health, and more.
			</p>
			<p class="mt-4 text-base leading-relaxed text-gray-700">
				Explore our media library below or visit
				<a
					href="https://barbarakohlerseminars.com/media"
					target="_blank"
					rel="noopener noreferrer"
					class="text-brand underline hover:text-brand/80"
				>
					Barbara Kohler Seminars
				</a>{' '}
				for additional educational resources and seminar recordings.
			</p>
		</div>
	</section>

	<!-- Wix Music Player -->
	<section class="py-20">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">Listen Now</p>
			<h2 class="section-title mb-8">Media</h2>
			<div class="w-full overflow-hidden rounded-lg shadow-md">
				<iframe
					title="Wix Music"
					aria-label="Wix Music"
					src="https://tpa.wixapps.net/music-server/music-widget?pageId=lex6o&compId=comp-m05dh5d0&viewerCompId=comp-m05dh5d0&siteRevision=163&viewMode=site&deviceType=desktop&locale=en&tz=America%2FNew_York&regionalLanguage=en&width=767&height=547&styleId=orig_bandarasignature&instance=blWpffr_OXk7JEiIahwzGRX1ylROVS_6YoI1Wtq4KzE.&currency=USD&currentCurrency=USD&commonConfig=%7B%22brand%22%3A%22wix%22%2C%22host%22%3A%22VIEWER%22%2C%22bsi%22%3A%2284b54612-1cf5-467c-85cd-a80ecc66ece4%7C1%22%2C%22siteRevision%22%3A%22163%22%2C%22renderingFlow%22%3A%22NONE%22%2C%22language%22%3A%22en%22%2C%22locale%22%3A%22en-us%22%2C%22BSI%22%3A%2284b54612-1cf5-467c-85cd-a80ecc66ece4%7C1%22%7D&currentRoute=.%2Fmedia&externalId=2e5b58b1-0096-4b5a-9acb-b07025b4b7da&vsi=c270efc6-7d93-4fdb-9400-f31bcdd954f7"
					allowfullscreen=""
					allowtransparency="true"
					allowvr="true"
					frameborder="0"
					allow="clipboard-write;autoplay;camera;microphone;geolocation;vr"
					class="w-full"
					style="height: 547px;"
				></iframe>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-white py-20">
		<div class="container text-center">
			<h2 class="text-3xl font-bold uppercase tracking-caps text-brand">
				Have a Media Inquiry?
			</h2>
			<p class="mx-auto mt-6 max-w-xl text-base text-gray-600">
				For speaking requests, interview inquiries, or media partnerships, please reach out to us directly.
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a
					href="https://barbara-kohler.clientsecure.me/contact-widget"
					target="_blank"
					rel="noopener noreferrer"
					class="btn-primary"
				>
					Get in Touch
				</a>
				<a
					href="tel:2527588636"
					class="inline-block border-2 border-brand px-8 py-3 text-xs font-bold uppercase tracking-ui text-brand transition hover:bg-brand hover:text-white"
				>
					Call 252-758-8636
				</a>
			</div>
		</div>
	</section>
</Layout>
