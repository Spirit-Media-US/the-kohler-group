---
import { sanityClient, urlFor } from '../../lib/sanity.ts';
import Layout from '@layouts/Layout.astro';
const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{
  phone, email, barbaraEmail, officeEmail, bookingUrl,
  facebook, instagram,
  heroImage, aboutHeroImage, defaultHeroImage, logo
}`);

---

<Layout
	title="Media | The Kohler Group, PLLC"
	description="Media resources, interviews, articles, and educational content from The Kohler Group, PLLC — Christian counseling insights for your mental health journey."
>
	<!-- Hero -->
	<section
		class="relative flex h-[250px] items-center justify-center bg-cover bg-top bg-no-repeat"
		style="background-image: url('https://cdn.sanity.io/images/2bom5gqg/production/a0bbde8a51ad33bc1a14aeeb0c5d87eeede972c1-1905x196.jpg')"
	>
		<div class="absolute inset-0 bg-brand/80"></div>
		<div class="container relative z-10 text-center">
			<h1 class="text-4xl font-bold uppercase tracking-caps text-white sm:text-5xl">
				Media
			</h1>
		</div>
	</section>

	<!-- Intro -->
	<section class="py-20">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">Resources & Content</p>
			<h2 class="section-title mb-8">Education Through Media</h2>
			<p class="text-base leading-relaxed text-gray-700">
				The Kohler Group is committed to equipping individuals, couples, and families with
				practical, faith-grounded mental health resources. Through interviews, articles,
				videos, and educational content, our team shares insights on Christian counseling,
				trauma recovery, marriage health, and more.
			</p>
			</div>
	</section>

	<!-- Audio Player -->
	<section class="pb-20 pt-10">
		<div class="container max-w-4xl">
			<p class="section-label mb-4">Listen Now</p>
			<h2 class="section-title mb-8">Media</h2>
			<div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
				<!-- Track List -->
				<div id="track-list" class="divide-y divide-gray-100">
					{[
						{ title: 'Anxiety', file: 'https://pub-d77219c850804c8ca2ddc9c193465856.r2.dev/audio/The Kohler Group PLLC - Anxiety.mp3' },
						{ title: 'Change', file: 'https://pub-d77219c850804c8ca2ddc9c193465856.r2.dev/audio/The Kohler Group PLLC - Change.mp3' },
						{ title: 'Grief', file: 'https://pub-d77219c850804c8ca2ddc9c193465856.r2.dev/audio/The Kohler Group PLLC - Grief.mp3' },
						{ title: 'Honesty', file: 'https://pub-d77219c850804c8ca2ddc9c193465856.r2.dev/audio/The Kohler Group PLLC - Honesty.mp3' },
						{ title: 'Joy', file: 'https://pub-d77219c850804c8ca2ddc9c193465856.r2.dev/audio/The Kohler Group PLLC - Joy.mp3' },
						{ title: 'Turmoil in Relationships', file: 'https://pub-d77219c850804c8ca2ddc9c193465856.r2.dev/audio/The Kohler Group PLLC - Turmoil in Relationships.mp3' },
					].map(({ title, file }, i) => (
						<div class="track-row group py-3" data-src={file} data-index={i}>
							<div class="flex cursor-pointer items-center gap-4">
								<!-- Play button -->
								<button class="play-btn flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full border-2 border-gray-300 text-gray-400 transition group-hover:border-brand group-hover:text-brand">
									<svg class="play-icon h-3 w-3 translate-x-[1px]" fill="currentColor" viewBox="0 0 16 16">
										<path d="M3 2.5l10 5.5-10 5.5V2.5z"/>
									</svg>
									<svg class="pause-icon hidden h-3 w-3" fill="currentColor" viewBox="0 0 16 16">
										<path d="M3 2h3v12H3zm7 0h3v12h-3z"/>
									</svg>
								</button>
								<!-- Title -->
								<span class="flex-1 text-sm font-medium text-brand">{title}</span>
								<!-- Right side: duration (default) + hover actions -->
								<div class="flex items-center gap-2">
									<!-- Share wrap — hover shows dropdown -->
									<div class="share-wrap relative">
										<button
											class="share-toggle hidden h-6 w-6 items-center justify-center text-gray-400 transition hover:text-brand group-hover:flex"
											title="Share"
										>
											<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
											</svg>
										</button>
										<!-- Share dropdown -->
										<div class="share-dropdown pointer-events-none absolute right-0 top-7 z-20 flex items-center gap-1 rounded-lg border border-gray-200 bg-white px-3 py-2 shadow-md opacity-0 transition-opacity">
											<a class="share-fb flex h-7 w-7 items-center justify-center rounded text-xs font-bold text-white transition hover:opacity-80" style="background:#1877F2" href="#" target="_blank" rel="noopener noreferrer" title="Share on Facebook">f</a>
											<a class="share-tw flex h-7 w-7 items-center justify-center rounded bg-black text-xs font-bold text-white transition hover:opacity-80" href="#" target="_blank" rel="noopener noreferrer" title="Share on X">
												<svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
											</a>
											<a class="share-fb flex h-7 w-7 items-center justify-center rounded text-xs font-bold text-white transition hover:opacity-80" style="background:#35465c" href="#" target="_blank" rel="noopener noreferrer" title="Share on Tumblr">t</a>
											<a class="share-bl flex h-7 w-7 items-center justify-center rounded text-xs font-bold text-white transition hover:opacity-80" style="background:#ff5722" href="#" target="_blank" rel="noopener noreferrer" title="Share on Blogger">B</a>
											<button class="copy-link flex h-7 w-7 items-center justify-center rounded border border-brand text-brand transition hover:bg-brand hover:text-white" title="Copy link">
												<svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
											</button>
										</div>
									</div>
									<!-- Playlist icon (decorative) -->
									<button class="hidden h-6 w-6 items-center justify-center text-gray-400 transition hover:text-brand group-hover:flex" title="Track list">
										<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 6h14v2H3zm0 5h14v2H3zm0 5h10v2H3zm16-1v6l5-3z"/></svg>
									</button>
									<!-- Duration (hidden on hover) -->
									<span class="duration text-xs text-gray-400 group-hover:invisible">--:--</span>
								</div>
							</div>
							<!-- Per-track progress bar -->
							<div class="track-progress mt-2 hidden px-1">
								<div class="h-0.5 w-full overflow-hidden rounded-full bg-gray-200">
									<div class="track-bar h-0.5 rounded-full bg-brand transition-all" style="width:0%"></div>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&display=swap" rel="stylesheet" />

	<script>
		const rows = document.querySelectorAll('.track-row');
		let current = null;
		let audio = new Audio();

		function fmt(s) {
			if (!isFinite(s)) return '--:--';
			const m = Math.floor(s / 60), sec = Math.floor(s % 60);
			return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
		}

		function resetRow(r) {
			r.querySelector('.play-icon').classList.remove('hidden');
			r.querySelector('.pause-icon').classList.add('hidden');
			r.querySelector('.play-btn').classList.remove('border-brand','text-brand');
			r.querySelector('.play-btn').classList.add('border-gray-300','text-gray-400');
			r.querySelector('.track-progress').classList.add('hidden');
		}

		rows.forEach((row) => {
			// Preload duration
			const tmp = new Audio(row.dataset.src);
			tmp.addEventListener('loadedmetadata', () => {
				row.querySelector('.duration').textContent = fmt(tmp.duration);
			});

			// Play/pause on row click (but not on share wrap clicks)
			row.querySelector('.flex.cursor-pointer').addEventListener('click', (e) => {
				if (e.target.closest('.share-wrap')) return;
				const isSame = current === row;
				rows.forEach(resetRow);
				if (isSame && !audio.paused) {
					audio.pause();
					current = null;
					return;
				}
				if (!isSame) { audio.src = row.dataset.src; current = row; }
				audio.play();
				row.querySelector('.play-icon').classList.add('hidden');
				row.querySelector('.pause-icon').classList.remove('hidden');
				row.querySelector('.play-btn').classList.add('border-brand','text-brand');
				row.querySelector('.play-btn').classList.remove('border-gray-300','text-gray-400');
				row.querySelector('.track-progress').classList.remove('hidden');
			});

			// Share dropdown hover
			const wrap = row.querySelector('.share-wrap');
			const dropdown = row.querySelector('.share-dropdown');
			wrap.addEventListener('mouseenter', () => {
				dropdown.classList.add('pointer-events-auto','opacity-100');
				dropdown.classList.remove('pointer-events-none','opacity-0');
			});
			wrap.addEventListener('mouseleave', () => {
				dropdown.classList.remove('pointer-events-auto','opacity-100');
				dropdown.classList.add('pointer-events-none','opacity-0');
			});

			// Set share URLs
			const pageUrl = encodeURIComponent(window.location.href);
			const trackTitle = encodeURIComponent('The Kohler Group — ' + row.querySelector('span.text-brand').textContent);
			row.querySelector('.share-fb').href = `https://www.facebook.com/sharer/sharer.php?u=${pageUrl}`;
			row.querySelector('.share-tw').href = `https://twitter.com/intent/tweet?url=${pageUrl}&text=${trackTitle}`;

			// Copy link
			row.querySelector('.copy-link').addEventListener('click', (e) => {
				e.stopPropagation();
				navigator.clipboard.writeText(window.location.href);
			});
		});

		// Update per-track progress bar
		audio.addEventListener('timeupdate', () => {
			if (current && audio.duration) {
				current.querySelector('.track-bar').style.width = (audio.currentTime / audio.duration * 100) + '%';
			}
		});

		audio.addEventListener('ended', () => {
			if (current) resetRow(current);
			current = null;
		});

	</script>

	<!-- CTA -->
	<section class="bg-white py-20">
		<div class="container text-center">
			<h2 class="text-3xl font-bold uppercase tracking-caps text-brand">
				Have a Media Inquiry?
			</h2>
			<p class="mx-auto mt-6 max-w-xl text-base text-gray-600">
				For speaking requests, interview inquiries, or media partnerships, please reach out to us directly.
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a
					href={settings?.bookingUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="btn-primary"
				>
					Get in Touch
				</a>
				<a
					href={`tel:${settings?.phone?.replace(/-/g, '')}`}
					class="inline-block border-2 border-brand px-8 py-3 text-xs font-bold uppercase tracking-ui text-brand transition hover:bg-brand hover:text-white"
				>
					Call {settings?.phone}
				</a>
			</div>
		</div>
	</section>
</Layout>
