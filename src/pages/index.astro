---
import Layout from '@layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const settings = await sanityClient.fetch(`*[_type=="siteSettings"][0]{
  phone, email, barbaraEmail, officeEmail, bookingUrl,
  facebook, instagram,
  heroImage, aboutHeroImage, defaultHeroImage, logo
}`);
// Mobile-first: preload a smaller webp hero for LCP on mobile
const heroMobileUrl = settings?.heroImage
	? urlFor(settings.heroImage).width(800).format('webp').quality(75).url()
	: '';
const heroDesktopUrl = settings?.heroImage
	? urlFor(settings.heroImage).width(1600).format('webp').quality(80).url()
	: '';
const heroPreloadUrl = heroMobileUrl;
---

<Layout
	title="Christian Counseling Huntersville NC | Barbara Kohler & The Kohler Group"
	description="Barbara Kohler offers Christian counseling, marriage intensives, and individual therapy in Huntersville, NC. Faith-based psychotherapy near Charlotte."
	heroPreload={heroPreloadUrl}
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "The Kohler Group PLLC",
			"url": "https://thekohlergroup.net",
			"description": "Christian counseling, marriage intensives, and individual therapy in Huntersville, NC.",
			"publisher": {
				"@type": "Organization",
				"name": "The Kohler Group, PLLC",
				"url": "https://thekohlergroup.net"
			}
		})}></script>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thekohlergroup.net/" },
				{ "@type": "ListItem", "position": 2, "name": "Marriage Intensives", "item": "https://thekohlergroup.net/intensives/marriage" },
				{ "@type": "ListItem", "position": 3, "name": "Individual Intensives", "item": "https://thekohlergroup.net/intensives/individual" },
				{ "@type": "ListItem", "position": 4, "name": "Our Therapists", "item": "https://thekohlergroup.net/our-therapists" },
				{ "@type": "ListItem", "position": 5, "name": "Testimonials", "item": "https://thekohlergroup.net/testimonials" }
			]
		})}></script>
	</Fragment>
	<!-- ============================================================
	     Hero — beach image, light overlay, centered headline only
	     ============================================================ -->
	<section
		class="relative flex min-h-[420px] md:min-h-[65vh] items-center justify-center overflow-hidden"
	>
		{heroMobileUrl && (
			<picture>
				<source media="(min-width: 768px)" srcset={heroDesktopUrl} />
				<img
					src={heroMobileUrl}
					alt=""
					width="1600"
					height="900"
					fetchpriority="high"
					loading="eager"
					decoding="async"
					class="absolute inset-0 h-full w-full object-cover"
				/>
			</picture>
		)}
		<div class="absolute inset-0 bg-brand/40"></div>
		<div class="container relative z-10 py-20 text-center">
			<h1
				class="mx-auto max-w-3xl text-3xl font-light uppercase tracking-ultra text-white sm:text-4xl lg:text-5xl"
			>
				The Future Depends on What You Do in the Present.
			</h1>
			<p class="mx-auto mt-4 max-w-xl text-lg font-light text-white/90 sm:text-xl">
				Christian Counseling in Huntersville, NC
			</p>
			<a
				href={settings?.bookingUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="mt-8 inline-block rounded-full bg-white px-10 py-3 text-xs font-bold uppercase tracking-ui text-brand transition hover:bg-white/90"
			>
				Get Started
			</a>
		</div>
	</section>

	<!-- ============================================================
	     Intro — plain paragraphs, no heading
	     ============================================================ -->
	<section class="py-20">
		<div class="container max-w-3xl">
			<p class="text-base leading-relaxed text-brand sm:text-lg">
				You can feel better after a talk with a close friend or relative when dealing with moderate
				or severe emotional distress. However, this relief is often temporary. Talking with a
				trained professional helps alleviate emotional distress. Applying proven Biblical Principles
				brings about lasting change that is undeniable. We want to help you move forward in your
				God given purpose.
			</p>
			<p class="mt-6 text-base leading-relaxed text-brand sm:text-lg">
				Our therapists are trained professionals who operate from a Biblical world view. We use
				Re-decision Therapy, EMDR, TRET (Trauma Resolution Energy Therapy), CBT-TF, and other
				techniques to treat our clients with the appropriate modality. We care about people and
				want to help you realize the grace of God in your own life. Each therapist has their own
				niche and has a track record of helping many people navigate through difficult circumstances
				to find the peace that only God can give. Your emotional health affects your spiritual
				life, finances, relationships, and career. Make your emotional health a priority and start
				the healing process today.
			</p>
		</div>
	</section>

	<!-- ============================================================
	     Services — dark navy, icons, pill Learn More buttons
	     ============================================================ -->
	<section class="bg-white pb-16 pt-4">
		<div class="container grid grid-cols-1 gap-6 md:grid-cols-3">
			<!-- Marriage Intensives -->
			<div class="flex flex-col items-center rounded-lg bg-brand text-center overflow-hidden">
				<img
					src="https://cdn.sanity.io/images/2bom5gqg/production/79bc51e151e87d59cb1cc31823371b8bdbb30a63-4349x2903.jpg?w=600&fm=webp&q=75"
					alt="Marriage Intensives"
					class="w-full object-cover"
					style="max-height: 220px; object-fit: cover;"
					loading="lazy"
				/>
				<div class="flex flex-col items-center py-12 px-10 w-full">
				<!-- Icon: two interlocking rings -->
				<svg
					class="mx-auto mb-6 h-14 w-14 text-white"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					viewBox="0 0 56 56"
					aria-hidden="true"
				>
					<circle cx="20" cy="28" r="13"></circle>
					<circle cx="36" cy="28" r="13"></circle>
				</svg>
				<h2 class="text-sm font-bold uppercase tracking-caps text-white">
					Marriage<br />Intensives
				</h2>
				<a
					href="/intensives/marriage"
					class="mt-6 rounded-full border border-white px-8 py-2 text-xs font-bold uppercase tracking-ui text-white transition hover:bg-white hover:text-brand"
				>
					Learn More
				</a>
				</div>
			</div>

			<!-- Therapy Sessions -->
			<div class="flex flex-col items-center rounded-lg bg-brand text-center overflow-hidden">
				<img
					src="https://cdn.sanity.io/images/2bom5gqg/production/2ba073373a307d8e08b3a4b462d5e57c2255d573-7000x4667.jpg?w=600&fm=webp&q=75"
					alt="Therapy Sessions"
					class="w-full object-cover"
					style="max-height: 220px; object-fit: cover;"
					loading="lazy"
				/>
				<div class="flex flex-col items-center py-12 px-10 w-full">
				<!-- Icon: speech bubble with dots -->
				<svg
					class="mx-auto mb-6 h-14 w-14 text-white"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					viewBox="0 0 56 56"
					aria-hidden="true"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M10 14h36a3 3 0 013 3v18a3 3 0 01-3 3H18l-8 6V17a3 3 0 013-3z"></path>
					<circle cx="22" cy="25" r="2" fill="currentColor" stroke="none"></circle>
					<circle cx="28" cy="25" r="2" fill="currentColor" stroke="none"></circle>
					<circle cx="34" cy="25" r="2" fill="currentColor" stroke="none"></circle>
				</svg>
				<h2 class="text-sm font-bold uppercase tracking-caps text-white">
					Therapy<br />Sessions
				</h2>
				<a
					href="/our-therapists"
					class="mt-6 rounded-full border border-white px-8 py-2 text-xs font-bold uppercase tracking-ui text-white transition hover:bg-white hover:text-brand"
				>
					Learn More
				</a>
				</div>
			</div>

			<!-- Individual Intensives -->
			<div class="flex flex-col items-center rounded-lg bg-brand text-center overflow-hidden">
				<img
					src="https://cdn.sanity.io/images/2bom5gqg/production/072edeab37e3c23c7441d53519ec70df92ad873a-5616x3744.jpg?w=600&fm=webp&q=75"
					alt="Individual Intensives"
					class="w-full object-cover"
					style="max-height: 220px; object-fit: cover;"
					loading="lazy"
				/>
				<div class="flex flex-col items-center py-12 px-10 w-full">
				<!-- Icon: two person silhouettes -->
				<svg
					class="mx-auto mb-6 h-14 w-14 text-white"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					viewBox="0 0 56 56"
					aria-hidden="true"
				>
					<circle cx="20" cy="16" r="7"></circle>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M4 46c0-8.837 7.163-16 16-16s16 7.163 16 16"></path>
					<circle cx="40" cy="16" r="7"></circle>
					<path stroke-linecap="round" stroke-linejoin="round" d="M40 30c5 0 12 4.5 12 16"></path>
				</svg>
				<h2 class="text-sm font-bold uppercase tracking-caps text-white">
					Individual<br />Intensives
				</h2>
				<a
					href="/intensives/individual"
					class="mt-6 rounded-full border border-white px-8 py-2 text-xs font-bold uppercase tracking-ui text-white transition hover:bg-white hover:text-brand"
				>
					Learn More
				</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Photo Gallery -->
	<section class="bg-white py-4">
		<div class="container">
			<div class="grid grid-cols-2 gap-4 md:grid-cols-4">
				<div class="overflow-hidden rounded-lg">
					<img src="https://cdn.sanity.io/images/2bom5gqg/production/76e2c98fa000dda7199aba5df5525f7b38d759ba-468x311.jpg?w=468&h=311&fit=crop&fm=webp&q=75" alt="The Kohler Group" class="h-52 w-full object-cover transition duration-500 hover:scale-105" loading="lazy" />
				</div>
				<div class="overflow-hidden rounded-lg">
					<img src="https://cdn.sanity.io/images/2bom5gqg/production/64dcec02ccd61d4a70f553ab23a09f8a3b379c3d-428x364.jpg?w=468&h=311&fit=crop&fm=webp&q=75" alt="The Kohler Group" class="h-52 w-full object-cover transition duration-500 hover:scale-105" loading="lazy" />
				</div>
				<div class="overflow-hidden rounded-lg">
					<img src="https://cdn.sanity.io/images/2bom5gqg/production/5529c4b2bf6b0bda291a530cff7973f3ccbc5a71-468x311.jpg?w=468&h=311&fit=crop&fm=webp&q=75" alt="The Kohler Group" class="h-52 w-full object-cover transition duration-500 hover:scale-105" loading="lazy" />
				</div>
				<div class="overflow-hidden rounded-lg">
					<img src="https://cdn.sanity.io/images/2bom5gqg/production/bf1492d28ee65b78bf5cd8baef40b10f50022c8c-415x349.jpg?w=468&h=311&fit=crop&fm=webp&q=75" alt="The Kohler Group" class="h-52 w-full object-cover transition duration-500 hover:scale-105" loading="lazy" />
				</div>
			</div>
		</div>
	</section>
</Layout>
